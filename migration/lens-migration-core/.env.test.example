# .env.test — Live Integration 测试环境变量配置
# 此文件已加入 .gitignore，不会提交到 git。
#
# 配置后，在 IDEA 或命令行运行 pytest 时，Live Integration 测试会自动运行，
# 无需每次手动传入环境变量。
#
# ── GitHub Models ──────────────────────────────────────────
# 获取方式：https://github.com/settings/tokens → Generate new token (classic)
# 勾选 public_repo 即可，无需其他权限。
#
GITHUB_TOKEN=your_github_pat_here

# ── 本地 Ollama ────────────────────────────────────────────
OLLAMA_LOCAL_MODEL=qwen2.5-coder:3b
OLLAMA_LOCAL_URL=http://localhost:11434/v1

# ── 远程 Ollama（10.99.79.20，通过 SSH 隧道访问）──────────
OLLAMA_REMOTE_MODEL=qwen2.5-coder:14b
OLLAMA_REMOTE_URL=http://localhost:11435/v1
OLLAMA_REMOTE_HOST=10.99.79.20
OLLAMA_REMOTE_USER=air
OLLAMA_REMOTE_PASS=air@2026
OLLAMA_REMOTE_PORT=11434
OLLAMA_TUNNEL_LOCAL_PORT=11435

# ── 切换目标：local 或 remote ─────────────────────────────
# 改这一行即可切换，或运行时传 OLLAMA_TARGET=local
# 注意：本地模型因网络问题无法下载，请使用 remote（10.99.79.20 RTX 4090）
OLLAMA_TARGET=remote
