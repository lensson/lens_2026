<#if dscp0\-mpbit?has_content>
                <classifiers>
                  <name>policy-${dscp\-2\-mpbit\-policy}_classifier0</name>
                </classifiers>
</#if>
<#if dscp1\-mpbit?has_content>
                <classifiers>
                  <name>policy-${dscp\-2\-mpbit\-policy}_classifier1</name>
                </classifiers>
</#if>
<#if dscp2\-mpbit?has_content>
