<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <multicast xmlns="urn:bbf:yang:bbf-mgmd">
        <mgmd>
          <multicast-vpn>
            <name>${vpn\-name}</name>
            <multicast-network-interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
              <name>${vpn\-network\-port\-name}</name>
            </multicast-network-interface>
          </multicast-vpn>
        </mgmd>
      </multicast>
<#if mc\-vlan?has_content>
      <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
        <interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
          <name>mc-np-${mc\-vlan}-NETWORK-VSI</name>
        </interface>
      </interfaces>
</#if>
    </config>
  </edit-config>
</rpc>
