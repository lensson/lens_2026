<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <licensing xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-licensing-app">
        <#if license\-key\-name?has_content>
          <cde-features>
            <license-key xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
              <name>${license\-key\-name}</name>
            </license-key>
          </cde-features>
        <#else>
	  <cde-features xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove"/>
        </#if>
      </licensing>
    </config>
  </edit-config>
</rpc>
