            <qos-policy-dynamic-association xmlns="urn:bbf:yang:nokia-sdan-interface-dynamic-association" ns0:operation="merge">
              <association-control xmlns:nokia-itf-dyn-id="urn:bbf:yang:nokia-sdan-interface-dynamic-association-identities">${policy\-association\-control}</association-control>
