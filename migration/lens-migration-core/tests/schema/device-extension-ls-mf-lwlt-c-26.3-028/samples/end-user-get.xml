<rpc message-id="EndUserCertificateGet" xmlns="urn:ietf:params:xml:ns:netconf:base:1.0">
  <get>
    <filter type="subtree">
      <certificate xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-certificate-management">
        <certificates-state>
          <end-user-certificates>
            <end-certs>
            <feature>${feature\-name}</feature>
              <certificates>
                <certificate>
                <cert>${certificate\-name}</cert>
                </certificate>
              </certificates>
            </end-certs>
          </end-user-certificates>
        </certificates-state>
      </certificate>
    </filter>
  </get>
</rpc>
