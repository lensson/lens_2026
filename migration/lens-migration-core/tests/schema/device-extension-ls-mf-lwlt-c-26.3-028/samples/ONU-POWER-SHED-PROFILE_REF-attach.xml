<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <hardware xmlns="urn:ietf:params:xml:ns:yang:ietf-hardware-mounted">
              <component>
                <name>${component\-name}</name>
                <class xmlns:ianahw="urn:ietf:params:xml:ns:yang:iana-hardware">ianahw:chassis</class>
                <power-shedding xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-hardware-power-shed-mounted">
                  <power-shedding-profile-ref>${power\-shed\-profile\-name}</power-shedding-profile-ref>
                  <backup-battery-monitoring>enabled</backup-battery-monitoring>
                </power-shedding>
              </component>
            </hardware>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>