<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <action xmlns="urn:ietf:params:xml:ns:yang:1">
    <hw:hardware-state xmlns:hw="urn:ietf:params:xml:ns:yang:ietf-hardware">
      <hw:component>
        <hw:name>${board\-name}</hw:name>
        <bbf-hw-rst-act:reset xmlns:bbf-hw-rst-act="urn:bbf:yang:bbf-hardware-reset-action">
          <#if reset\-type == "hardware-reset">
            <bbf-hw-rst-act:reset-type>bbf-hw-rst-act:${reset\-type}</bbf-hw-rst-act:reset-type>
          <#elseif reset\-type == "hardware-reset-to-default-configuration">
            <bbf-hw-rst-act:reset-type xmlns:nokia-hardware-reset-action-extension="urn:bbf:yang:nokia-hardware-reset-action-extension">nokia-hardware-reset-action-extension:${reset\-type}</bbf-hw-rst-act:reset-type>
	  <#elseif reset\-type == "hardware-reset-to-factory-datastore">
            <bbf-hw-rst-act:reset-type xmlns:nokia-hardware-reset-action-extension="urn:bbf:yang:nokia-hardware-reset-action-extension">nokia-hardware-reset-action-extension:${reset\-type}</bbf-hw-rst-act:reset-type>
	  <#elseif reset\-type == "hardware-reset-with-self-test">
            <bbf-hw-rst-act:reset-type xmlns:nokia-hardware-reset-action-extension="urn:bbf:yang:nokia-hardware-reset-action-extension">nokia-hardware-reset-action-extension:${reset\-type}</bbf-hw-rst-act:reset-type>
          </#if>
        </bbf-hw-rst-act:reset>
      </hw:component>
    </hw:hardware-state>
  </action>
</rpc>