<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <multicast xmlns="urn:bbf:yang:bbf-mgmd-mounted">
              <mgmd>
                <multicast-vpn>
                  <name>${vpn\-name}</name>
                  <multicast-channel>
                    <name>${multicast\-channel\-name}</name>
                    <network-interface>${network\-port\-name}</network-interface>
                    <ipv4>
                      <source-ipv4-address>${source\-ipv4\-address}</source-ipv4-address>
                      <group-ipv4-address>${group\-ipv4\-address}</group-ipv4-address>
                      <group-ipv4-address-end>${group\-ipv4\-address\-end}</group-ipv4-address-end>
                    </ipv4>
                  </multicast-channel>
                  <multicast-package>
                    <name>${multicast\-package\-name}</name>
                    <multicast-channel-list>${multicast\-channel\-name}</multicast-channel-list>
                  </multicast-package>
                </multicast-vpn>
              </mgmd>
            </multicast>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>