<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get-config>
    <source>
      <running/>
    </source>
    <filter type="subtree">
    <tm-profiles xmlns="urn:bbf:yang:bbf-qos-traffic-mngt">
