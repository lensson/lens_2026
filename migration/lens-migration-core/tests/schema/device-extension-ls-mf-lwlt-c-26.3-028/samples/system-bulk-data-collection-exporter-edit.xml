<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <ipfix xmlns="urn:ietf:params:xml:ns:yang:ietf-ipfix-psamp">
        <exportingProcess xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
          <name>${exporter\-name}</name>
          <exportMode>fallback</exportMode>
          <re-transmission-timeout xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipfix">${retransmission\-timeout}</re-transmission-timeout>
          <destination>
            <name>${collector\-name}</name>
            <priority xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipfix">${priority}</priority>
            <tcpExporter>
              <#if dest\-ip\-address?has_content>
              <destinationIPAddress>${dest\-ip\-address}</destinationIPAddress>
              <#elseif dest\-fqdn?has_content>
              <fqdn xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipfix">${dest\-fqdn}</fqdn>
              </#if>
              <destinationPort>${dest\-port}</destinationPort>
              <username xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipfix">${username}</username>
              <password xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipfix">${password}</password>
            </tcpExporter>
          </destination>
        </exportingProcess>
        <ipfix-exporting-enable xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipfix">true</ipfix-exporting-enable>
      </ipfix>
    </config>
  </edit-config>
</rpc>
