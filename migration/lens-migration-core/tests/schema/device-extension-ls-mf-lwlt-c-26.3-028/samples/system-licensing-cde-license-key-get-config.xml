<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get-config>
    <source>
      <running/>
    </source>
    <filter type="subtree">
      <licensing xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-licensing-app">
	<cde-features>
          <#if license\-key\-name?has_content>
            <license-key>
              <name>${license\-key\-name}</name>
            </license-key>
	  </#if>
	</cde-features>
      </licensing>
    </filter>
  </get-config>
</rpc>
