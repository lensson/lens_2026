<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="2">
  <action xmlns="urn:ietf:params:xml:ns:yang:1">
    <hardware-state xmlns="urn:ietf:params:xml:ns:yang:ietf-hardware">
      <component>
        <name>${component}</name>
        <software xmlns="urn:bbf:yang:bbf-software-image-management-one-dot-one">
          <software>
            <name>${software\-name}</name>
            <revisions>
              <revision>
                <name>${download\-software\-name}</name>
                <activate-revision>
                  <#if default\-datastore?has_content && (default\-datastore == true || default\-datastore == false)>
                    <activate>
                      <with-default-datastore xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-software-image-management-extension">${default\-datastore}</with-default-datastore>
                    </activate>
                  <#else>
                    <activate/>
		              </#if>
                </activate-revision>
              </revision>
            </revisions>
          </software>
        </software>
      </component>
    </hardware-state>
  </action>
</rpc>
