<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="setSyslogRemoteCollector">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <syslog xmlns="urn:ietf:params:xml:ns:yang:ietf-syslog">
        <actions>
          <remote>
            <destination  xmlns:nc="urn:ietf:params:xml:ns:netconf:base:1.0" nc:operation="merge">
              <name>${syslog\-collector\-name}</name>
              <udp>
                <address>${ipaddress}</address>
                <port>${port}</port>
              </udp>
              <#if facility?has_content && severity?has_content>
                <facility-filter>
                    <facility-list>
                      <facility>${facility}</facility>
                      <severity>${severity}</severity>
                      <advanced-compare>
                        <#if advance\-action?has_content>
                            <action>${advance\-action}</action>
                        </#if>
                        <#if advance\-compare?has_content>
                            <compare>${advance\-compare}</compare>
                        </#if>
                      </advanced-compare>
                    </facility-list>
                </facility-filter>
              </#if>
              <#if pattern\-match?has_content>
                <pattern-match>${pattern\-match}</pattern-match>
              </#if>
            </destination>
          </remote>
        </actions>
      </syslog>
    </config>
  </edit-config>
</rpc>

