<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <pots-interworking-nodes xmlns="urn:bbf:yang:bbf-sip-voip-mounted">
              <pots-interworking>
                <name>${pots\-name}</name>
                <performance xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-voice-performance-management-mounted">
<#if ccpm\-failure\-tca\-profile?has_content>
                  <tca-pots-call-control-profile xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">${ccpm\-failure\-tca\-profile}</tca-pots-call-control-profile>
</#if>
<#if rtp\-failure\-tca\-profile?has_content>
                  <tca-pots-rtp-profile xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">${rtp\-failure\-tca\-profile}</tca-pots-rtp-profile>
</#if>
                </performance>
              </pots-interworking>
            </pots-interworking-nodes>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>