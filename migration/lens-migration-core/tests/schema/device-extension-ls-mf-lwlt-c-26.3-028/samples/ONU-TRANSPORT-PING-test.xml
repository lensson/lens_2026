<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <action xmlns="urn:ietf:params:xml:ns:yang:1">
    <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
      <onu>
        <name>${onu\-name}</name>
        <root>
          <ip-test xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ip-test-mounted">
            <ipv4>
              <ping>
                <test-name>${ping\-test\-name}</test-name>
                <source-interface>ip-host</source-interface>
<#if target\-ip\-address?has_content>
                <target-ip-address>${target\-ip\-address}</target-ip-address>
<#elseif target\-domain\-name?has_content>
                <target-domain-name>${target\-domain\-name}</target-domain-name>
</#if>
<#if count?has_content>
                <count>${count}</count>
</#if>
              </ping>
            </ipv4>
          </ip-test>
        </root>
      </onu>
    </onus>
  </action>
</rpc>