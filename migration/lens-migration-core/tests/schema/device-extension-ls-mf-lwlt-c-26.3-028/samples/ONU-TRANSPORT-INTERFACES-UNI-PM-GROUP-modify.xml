<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces-mounted">
              <interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
                <name>${onu_uni_intf}</name>
<#if eth\-port\-hw\-option == "ethernetCsmacd">
                <type xmlns:ianaift="urn:ietf:params:xml:ns:yang:iana-if-type-mounted">ianaift:ethernetCsmacd</type>
</#if>
                <performance xmlns="urn:bbf:yang:bbf-interfaces-performance-management-mounted">
                  <ethernet xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-interfaces-performance-management-mounted" xmlns:ns1="urn:ietf:params:xml:ns:netconf:base:1.0" ns1:operation="replace">
                    <ethernet-pm-group>${pm_group}</ethernet-pm-group>
                  </ethernet>
                </performance>
              </interface>
            </interfaces>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>