<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
<#if mc\-vlan?has_content>
      <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
        <interface>
          <name>mc-np-${mc\-vlan}-NETWORK-VSI</name>
          <type xmlns:bbfift="urn:bbf:yang:bbf-if-type">bbfift:vlan-sub-interface</type>
          <interface-usage xmlns="urn:bbf:yang:bbf-interface-usage">
            <interface-usage>network-port</interface-usage>
          </interface-usage>
<#if network\-port\-name?has_content>
          <subif-lower-layer xmlns="urn:bbf:yang:bbf-sub-interfaces">
            <interface>${network\-port\-name}</interface>
          </subif-lower-layer>
</#if>
          <enabled>true</enabled>
          <inline-frame-processing xmlns="urn:bbf:yang:bbf-sub-interfaces">
            <ingress-rule>
              <rule>
                <name>rule_1</name>
                <priority>100</priority>
                <flexible-match>
                  <match-criteria xmlns="urn:bbf:yang:bbf-sub-interface-tagging">
                    <tag>
                      <index>0</index>
                      <dot1q-tag>
                        <tag-type xmlns:bbf-dot1qt="urn:bbf:yang:bbf-dot1q-types">bbf-dot1qt:c-vlan</tag-type>
                        <vlan-id>${mc\-vlan}</vlan-id>
                        <pbit>any</pbit>
                        <dei>any</dei>
                      </dot1q-tag>
                    </tag>
                  </match-criteria>
                </flexible-match>
                <ingress-rewrite>
                  <pop-tags xmlns="urn:bbf:yang:bbf-sub-interface-tagging">1</pop-tags>
                </ingress-rewrite>
              </rule>
            </ingress-rule>
            <egress-rewrite>
              <push-tag xmlns="urn:bbf:yang:bbf-sub-interface-tagging">
                <index>0</index>
                <dot1q-tag>
                  <tag-type xmlns:bbf-dot1qt="urn:bbf:yang:bbf-dot1q-types">bbf-dot1qt:c-vlan</tag-type>
                  <vlan-id>${mc\-vlan}</vlan-id>
                  <pbit-from-tag-index>0</pbit-from-tag-index>
                  <dei-from-tag-index>0</dei-from-tag-index>
                </dot1q-tag>
              </push-tag>
            </egress-rewrite>
          </inline-frame-processing>
          <egress-qos-policy-profile xmlns="urn:bbf:yang:bbf-qos-policies">${network\-policy\-profile\-name}</egress-qos-policy-profile>
        </interface>
      </interfaces>
<#elseif ibridge\-name?has_content>
      <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
        <interface>
          <name>${ibridge\-name}-NETWORK-VSI</name>
          <egress-qos-policy-profile xmlns="urn:bbf:yang:bbf-qos-policies">${network\-policy\-profile\-name}</egress-qos-policy-profile>
        </interface>
      </interfaces>
</#if>
      <multicast xmlns="urn:bbf:yang:bbf-mgmd">
        <mgmd>
          <multicast-vpn>
            <name>${vpn\-name}</name>
            <multicast-network-interface>
              <name>${vpn\-network\-port\-name}</name>
<#if mc\-vlan?has_content>
              <single-uplink-interface-data>
                  <vlan-sub-interface>mc-np-${mc\-vlan}-NETWORK-VSI</vlan-sub-interface>
              </single-uplink-interface-data>
<#elseif ibridge\-name?has_content>
              <single-uplink-interface-data>
                  <vlan-sub-interface>${ibridge\-name}-NETWORK-VSI</vlan-sub-interface>
              </single-uplink-interface-data>
</#if>
<#if network\-port\-proxy\-ipv4\-address?has_content>
              <ipv4-address>${network\-port\-proxy\-ipv4\-address}</ipv4-address>
</#if>
            </multicast-network-interface>
          </multicast-vpn>
        </mgmd>
      </multicast>
    </config>
  </edit-config>
</rpc>
