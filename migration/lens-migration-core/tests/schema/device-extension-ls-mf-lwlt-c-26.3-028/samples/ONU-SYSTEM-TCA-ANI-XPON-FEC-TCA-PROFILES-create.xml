<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <tca-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-hardware-profiles-mounted">
              <pm-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-hardware-pm-threshold-profiles-mounted">
                <xpon-fec-error-profile xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-xponani-pm-threshold-profiles-mounted" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
                  <name>${xpon\-fec\-error\-profile}</name>
<#if corrected\-bytes\-threshold?has_content>
                  <corrected-bytes-threshold>${corrected\-bytes\-threshold}</corrected-bytes-threshold>
</#if>
<#if corrected\-code\-words\-threshold?has_content>
                  <corrected-code-words-threshold>${corrected\-code\-words\-threshold}</corrected-code-words-threshold>
</#if>
<#if uncorrectable\-code\-words\-threshold?has_content>
                  <uncorrectable-code-words-threshold>${uncorrectable\-code\-words\-threshold}</uncorrectable-code-words-threshold>
</#if>
<#if fec\-seconds\-threshold?has_content>
                  <fec-seconds-threshold>${fec\-seconds\-threshold}</fec-seconds-threshold>
</#if>
                </xpon-fec-error-profile>
              </pm-profiles>
            </tca-profiles>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>