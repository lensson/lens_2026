<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
   <edit-config>
      <target>
         <running/>
      </target>
      <default-operation>merge</default-operation>
      <test-option>set</test-option>
      <error-option>stop-on-error</error-option>
      <config>
            <clock-ssm-out-vlan-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-conf-clock-frequency">
    <clock-ssm-out-vlan-profile xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
       <name>${vlan\-profile\-name}</name>
       <#if ssm\-out\-vlan\-id?has_content>
         <ssm-out-vlan-id>${ssm\-out\-vlan\-id}</ssm-out-vlan-id>
       </#if>
    </clock-ssm-out-vlan-profile>
     </clock-ssm-out-vlan-profiles>
                 <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
     <interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
       <name>BP_Eth</name>
       <ssm-in xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-conf-clock-frequency">
       <ssm-in-enable>true</ssm-in-enable>
       </ssm-in>
     </interface>
     <interface>
        <name>${lt\-interface\-name}</name>
        <ssm-out xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-conf-clock-frequency">
          <#if ssm\-out\-enable?has_content>
            <ssm-out-enable>${ssm\-out\-enable}</ssm-out-enable>
          </#if>
        </ssm-out>
        <ssm-out-profile-ref xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-conf-clock-frequency">vlan_4088</ssm-out-profile-ref>
      </interface>              
     </interfaces>
      </config>
   </edit-config>
</rpc>

