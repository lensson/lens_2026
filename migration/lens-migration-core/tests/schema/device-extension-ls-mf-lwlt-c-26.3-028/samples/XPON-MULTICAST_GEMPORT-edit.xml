<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <xpon xmlns="urn:bbf:yang:bbf-xpon">
        <multicast-gemports>
          <multicast-gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
            <name>${multicast\-gemport\-name}</name>
<#if gemport\-id?has_content>
            <gemport-id>${gemport\-id}</gemport-id>
</#if>
<#if interface?has_content>
            <interface>${interface}</interface>
</#if>
            <is-broadcast>false</is-broadcast>
          </multicast-gemport>
        </multicast-gemports>
      </xpon>
    </config>
  </edit-config>
</rpc>
