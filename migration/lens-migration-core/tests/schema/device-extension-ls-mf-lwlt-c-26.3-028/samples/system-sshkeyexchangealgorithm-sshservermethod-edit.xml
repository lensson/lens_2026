<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <confdConfig xmlns="http://tail-f.com/ns/confd_dyncfg/1.0">
        <ssh>
          <algorithms xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
            <#if kex?has_content>
              <kex>${kex}</kex>
            </#if>
            <#if serverhostkey?has_content>
              <serverHostKey>${serverhostkey}</serverHostKey>
            </#if>
          </algorithms>
        </ssh>
      </confdConfig>
    </config>
  </edit-config>
</rpc>
