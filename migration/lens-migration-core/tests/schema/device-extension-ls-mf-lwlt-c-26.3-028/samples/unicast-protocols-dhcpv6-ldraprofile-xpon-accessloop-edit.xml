<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
 	   <dhcpv6-ldra-profiles xmlns="urn:bbf:yang:bbf-ldra">
        <dhcpv6-ldra-profile xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
          <name>${dhcpv6\-profile\-name}</name>
		  <options>
	      <#if vendor\-specific\-information?has_content>
            <option>${vendor\-specific\-information}</option>
	       </#if>
           <#if vendor\-specific\-information?has_content && xpon\-access\-loop\-syntax?has_content>
            <xpon-access-loop-characteristics xmlns="urn:bbf:yang:bbf-xpon-access-line-characteristics-dhcpv6" xmlns:bbf-xpon-acc-type="urn:bbf:yang:bbf-xpon-access-line-characteristics-type">${xpon\-access\-loop\-syntax}</xpon-access-loop-characteristics>
	       </#if>
		   </options>
        </dhcpv6-ldra-profile>
       </dhcpv6-ldra-profiles>
    </config>
  </edit-config>
</rpc>
