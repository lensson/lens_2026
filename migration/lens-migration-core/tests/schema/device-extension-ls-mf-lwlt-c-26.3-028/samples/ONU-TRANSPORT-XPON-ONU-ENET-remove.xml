<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <hardware xmlns="urn:ietf:params:xml:ns:yang:ietf-hardware-mounted">
              <component xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
<#if eth\-port\-hw\-option== "veip" >
                <name>VEIPPORT${eth\-port\-hw\-number}</name>
                <class xmlns:bbf-hwt="urn:bbf:yang:bbf-hardware-types">bbf-hwt:transceiver</class>
<#else>
<#if special\-integrated\-ONUs?has_content && special\-integrated\-ONUs== true >
                <name>PORT_${eth\-port\-hw\-option}_${eth\-port\-hw\-number}</name>
                <class xmlns:bbf-hwt="urn:bbf:yang:bbf-hardware-types">bbf-hwt:rj45</class>
<#else>
<#if eth\-port\-hw\-option== "rj45" >
                <name>PORT_${eth\-port\-hw\-option}_${eth\-port\-hw\-number}</name>
                <class xmlns:bbf-hwt="urn:bbf:yang:bbf-hardware-types">bbf-hwt:rj45</class>
<#else>
<#if pluggable\-optical\-electrical\-SFP?has_content && pluggable\-optical\-electrical\-SFP== true >
                <name>PORT_${eth\-port\-hw\-option}_${eth\-port\-hw\-number}</name>
                <class xmlns:bbf-hwt="urn:bbf:yang:bbf-hardware-types">bbf-hwt:transceiver-link</class>
<#else>
                <name>PORT_${eth\-port\-hw\-option}_${eth\-port\-hw\-number}</name>
                <class xmlns:nokia-hwi="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-hardware-identities">nokia-hwi:${eth\-port\-hw\-option}</class>
</#if>
</#if>
</#if>
</#if>
              </component>
<#if pluggable\-optical\-electrical\-SFP?has_content && pluggable\-optical\-electrical\-SFP== true >
              <component xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <name>25G_transceiver</name>
                <class xmlns:bbf-hwt="urn:bbf:yang:bbf-hardware-types">bbf-hwt:transceiver</class>
              </component>
              <component xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <name>25G_cage</name>
                <class xmlns:nokia-hwi="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-hardware-identities">nokia-hwi:cage-uni</class>
              </component>
</#if>
            </hardware>
            <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces-mounted">
              <interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <name>${enet\-name}</name>
              </interface>
            </interfaces>
            <xpongemtcont xmlns="urn:bbf:yang:bbf-xpongemtcont-mounted">
              <gemports>
                <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                  <name>${enet\-name}-GEM0</name>
                </gemport>
                <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                  <name>${enet\-name}-GEM1</name>
                </gemport>
                <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                  <name>${enet\-name}-GEM2</name>
                </gemport>
                <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                  <name>${enet\-name}-GEM3</name>
                </gemport>
                <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                  <name>${enet\-name}-GEM4</name>
                </gemport>
                <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                  <name>${enet\-name}-GEM5</name>
                </gemport>
                <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                  <name>${enet\-name}-GEM6</name>
                </gemport>
                <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                  <name>${enet\-name}-GEM7</name>
                </gemport>
              </gemports>
            </xpongemtcont>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>