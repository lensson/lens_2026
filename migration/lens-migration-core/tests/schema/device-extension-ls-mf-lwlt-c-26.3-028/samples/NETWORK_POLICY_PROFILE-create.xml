<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
	<edit-config>
		<target>
			<running/>
		</target>
		<config>
			<qos-policy-profiles xmlns="urn:bbf:yang:bbf-qos-policies">
				<policy-profile xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
					<name>${network\-policy\-profile\-name}</name>
                    <#if igmp\-remarking\-policy\-name?has_content>
                    <policy-list>
                      <name>${igmp\-remarking\-policy\-name}</name>
                    </policy-list>
                    </#if>          				
                    <#if igmp\-tc\-policy\-name?has_content>
                    <policy-list>
                      <name>${igmp\-tc\-policy\-name}</name>
                    </policy-list>
                    </#if>
				</policy-profile>
			</qos-policy-profiles>
		</config>
	</edit-config>
</rpc>
