<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <intended-beyond-onu-v-vrefpoint xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-tr069-mgnt-mounted" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
              <reachable-tr069-servers>
                <reachable-tr069-server xmlns:ns1="urn:ietf:params:xml:ns:netconf:base:1.0" ns1:operation="merge">
                  <reference-onu-v-vrefpoint>${reference\-onu\-v\-vrefpoint}</reference-onu-v-vrefpoint>
                  <admin-state>${admin\-state}</admin-state>
                  <vlan-id>${management\-VLAN}</vlan-id>
                  <pbit>${management\-pbit}</pbit>
                  <dei>${management\-dei}</dei>
                  <uri>${ACS\-server\-uri}</uri>
                  <authentication>
                    <validation-scheme>${authentication\-validation\-scheme}</validation-scheme>
                    <user-name>${authentication\-user\-name}</user-name>
                    <password>${authentication\-user\-password}</password>
                  </authentication>
                </reachable-tr069-server>
              </reachable-tr069-servers>
            </intended-beyond-onu-v-vrefpoint>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>