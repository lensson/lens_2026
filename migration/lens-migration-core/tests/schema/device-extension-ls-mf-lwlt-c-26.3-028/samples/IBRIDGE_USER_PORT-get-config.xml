<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get-config>
    <source>
      <running/>
    </source>
    <filter>
      <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
        <interface>
          <name>${ibridge\-user\-port\-name}-VSI</name>
        </interface>
      </interfaces>
      <xpongemtcont xmlns="urn:bbf:yang:bbf-xpongemtcont">
      <gemports>
        <gemport>
          <interface>${ibridge\-user\-port\-name}-VSI</interface> 
        </gemport>
      </gemports>
      </xpongemtcont>
      <#if onu\-template\-cc\-name?has_content && onu\-name?has_content>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <template-parameters xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/onus-from-template">
            <interfaces>
              <interface>
                <template-ref>${onu\-template\-cc\-name}</template-ref>
              </interface>
            </interfaces>
          </template-parameters>
        </onu>
      </onus>
      </#if>
    </filter>
  </get-config>
</rpc>
