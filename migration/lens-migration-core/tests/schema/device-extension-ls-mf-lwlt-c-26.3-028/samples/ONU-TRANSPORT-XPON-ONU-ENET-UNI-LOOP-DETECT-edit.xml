<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces-mounted">
              <uni-loop-detection xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-uni-loop-detection-mounted" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
<#if enable\-flag?has_content>
                <enable>${enable\-flag}</enable>
</#if>
<#if auto\-shut\-off?has_content>
                <auto-shut-off>${auto\-shut\-off}</auto-shut-off>
</#if>
              </uni-loop-detection>
            </interfaces>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>