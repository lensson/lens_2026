<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">     	
        <interface>
          <name>${olt\-infrastructure\-name}-cpartition</name>
          <tm-root xmlns="urn:bbf:yang:bbf-qos-traffic-mngt">
            <scheduler-node xmlns="urn:bbf:yang:bbf-qos-enhanced-scheduling">
              <name>${scheduler\-name}</name>
              <queue-monitoring xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-qos-queue-monitoring-extension">
                <enable-statistics>${enable}</enable-statistics>
                <enable-performance>${enable}</enable-performance>
              </queue-monitoring>
            </scheduler-node>
          </tm-root>
        </interface>
      </interfaces>
    </config>
  </edit-config>
</rpc>
