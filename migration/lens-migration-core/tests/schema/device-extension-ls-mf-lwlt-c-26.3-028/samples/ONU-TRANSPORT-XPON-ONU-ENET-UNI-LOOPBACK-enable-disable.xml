<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <action xmlns="urn:ietf:params:xml:ns:yang:1">
    <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
      <onu>
        <name>${onu\-name}</name>
        <root>
          <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces-mounted">
            <interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
              <name>${enet\-name}</name>
              <loopback xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-itf-loopback-mounted">
<#if loopback\-flag == "enable">
                <enable>
<#if loopback\-duration?has_content>
                  <duration>${loopback\-duration}</duration>
</#if>
                </enable>
</#if>
<#if loopback\-flag == "disable">
                <disable/>
</#if>
              </loopback>
            </interface>
          </interfaces>
        </root>
      </onu>
    </onus>
  </action>
</rpc>