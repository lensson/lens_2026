<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <action xmlns="urn:ietf:params:xml:ns:yang:1">
      <users xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-aaa">
        <user>
          <name>${user\-name}</name>
          <authentication>
            <change-password>
              <old-password>${old\-password}</old-password>
              <new-password>${new\-password}</new-password>
              <confirm-password>${confirm\-password}</confirm-password>
            </change-password>
          </authentication>
        </user>
      </users>
  </action>
</rpc>



