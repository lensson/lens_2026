<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <remote-nf xmlns="urn:bbf:yang:bbf-olt-vomci">
        <nf-client>
          <enabled>false</enabled>
          <initiate>
            <remote-server>
              <name>${remoteserver}</name>
              <local-service-endpoint>${localservice}</local-service-endpoint>
              <grpc-client xmlns="urn:bbf:yang:bbf-olt-vomci-grpc-client">
                <access-point>
                  <name>${accesspoint}</name>
                  <grpc-transport-parameters>
                    <tcp-client-parameters xmlns="urn:bbf:yang:bbf-olt-vomci-grpc-client-tls">
                      <remote-address>${remoteaddress}</remote-address>
                      <remote-port>${remoteport}</remote-port>
                    </tcp-client-parameters>
                    <tls-client-parameters xmlns="urn:bbf:yang:bbf-olt-vomci-grpc-client-tls">
                      <client-identity>
                        <certificate>
                          <local-definition>
                            <cert>${cert}</cert>
                          </local-definition>
                        </certificate>
                      </client-identity>
                      <server-auth>
                        <pinned-ca-certs>${cagroup}</pinned-ca-certs>
                      </server-auth>
                    </tls-client-parameters>
                  </grpc-transport-parameters>
                </access-point>
              </grpc-client>
            </remote-server>
          </initiate>
        </nf-client>
      </remote-nf>
    </config>
  </edit-config>
</rpc>

