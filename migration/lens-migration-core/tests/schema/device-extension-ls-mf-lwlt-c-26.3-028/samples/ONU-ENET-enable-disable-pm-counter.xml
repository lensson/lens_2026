<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <template-parameters xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/onus-from-template">
            <interfaces>
              <interface>
                <template-ref>${onu\-template\-enet\-name}</template-ref>
                <pm-enable>${pm\-flag}</pm-enable>
              </interface>
            </interfaces>
          </template-parameters>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>
