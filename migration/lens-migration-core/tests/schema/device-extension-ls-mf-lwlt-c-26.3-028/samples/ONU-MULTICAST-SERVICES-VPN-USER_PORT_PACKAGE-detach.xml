                    <name>${user\-port\-name}</name>
                    <multicast-package xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">${multicast\-package\-name}</multicast-package>
                  </multicast-interface-to-host>
                </multicast-vpn>
              </mgmd>
            </multicast>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>