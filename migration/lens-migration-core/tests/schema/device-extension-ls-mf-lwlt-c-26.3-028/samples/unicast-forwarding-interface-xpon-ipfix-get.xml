<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get>
    <filter type="subtree">
      <interfaces-state xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
        <interface>
<#if ibridge\-user\-port\-name?has_content>
          <name>${ibridge\-user\-port\-name}-VSI</name>
<#elseif cc\-name?has_content>
          <name>${cc\-name}-USER-VSI</name>
<#else>
          <name/>
          <type xmlns:bbfift="urn:bbf:yang:bbf-if-type">bbfift:vlan-sub-interface</type>
</#if>
          <vsi-ipfix-xpon-info xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-vsi-xpon-info"/>
        </interface>
      </interfaces-state>
    </filter>
  </get>
</rpc>
