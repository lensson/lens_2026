<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <tca-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-hardware-profiles-mounted">
              <pm-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-hardware-pm-threshold-profiles-mounted">
                <xgponani-downstream-error-profile xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-xponani-pm-threshold-profiles-mounted" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
                  <name>${xgponani\-downstream\-error\-profile}</name>
<#if ploam\-mic\-error\-threshold?has_content>
                  <ploam-mic-error-threshold>${ploam\-mic\-error\-threshold}</ploam-mic-error-threshold>
</#if>
<#if omci\-mic\-error\-threshold?has_content>
                  <omci-mic-error-threshold>${omci\-mic\-error\-threshold}</omci-mic-error-threshold>
</#if>
                </xgponani-downstream-error-profile>
              </pm-profiles>
            </tca-profiles>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>