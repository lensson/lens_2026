<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get-config>
    <source>
      <running/>
    </source>
    <filter type="subtree">
      <multicast xmlns="urn:bbf:yang:bbf-mgmd">
        <mgmd>
          <multicast-vpn>
              <name>${vpn\-name}</name>
<#if multicast\-channel\-name?has_content>
              <multicast-channel>
                  <name>${multicast\-channel\-name}</name>
              </multicast-channel>
<#elseif detailed\-output == false>
              <multicast-channel>
                <name/>
              </multicast-channel>
<#else>
              <multicast-channel/>
</#if>
          </multicast-vpn>
        </mgmd>
      </multicast>
    </filter>
  </get-config>
</rpc>
