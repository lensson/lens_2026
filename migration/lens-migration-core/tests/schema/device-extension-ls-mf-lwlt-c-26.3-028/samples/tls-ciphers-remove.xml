<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <netconf-server xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-server">
        <call-home>
          <netconf-client>
            <name>${netconf\-client\-name}</name>
            <endpoints>
              <endpoint>
                <name>certificate_endpoint</name>
                <tls>
                  <hello-params>
                    <cipher-suites>
                      <cipher-suite xmlns:nc="urn:ietf:params:xml:ns:netconf:base:1.0"
                        xmlns:tlscsa="urn:ietf:params:xml:ns:yang:iana-tls-cipher-suite-algs"
                        nc:operation="remove">tlscsa:${cipher\-id}</cipher-suite>
                    </cipher-suites>
                  </hello-params>
                </tls>
              </endpoint>
            </endpoints>
          </netconf-client>
        </call-home>
      </netconf-server>
    </config>
  </edit-config>
</rpc>
