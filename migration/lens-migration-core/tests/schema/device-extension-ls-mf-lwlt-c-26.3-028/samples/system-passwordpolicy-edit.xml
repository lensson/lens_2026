<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <system-security xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-aaa">
        <password-policy xmlns:nc="urn:ietf:params:xml:ns:netconf:base:1.0" nc:operation="merge">
          <#if min\-length?has_content>
            <min-length>${min\-length}</min-length>
          </#if>
          <#if min\-num\-numeric\-char?has_content>
            <min-num-numeric-char>${min\-num\-numeric\-char}</min-num-numeric-char>
          </#if>
          <#if min\-num\-special\-char?has_content>
            <min-num-special-char>${min\-num\-special\-char}</min-num-special-char>
          </#if>
          <#if mixed\-case?has_content>
            <mixed-case>${mixed\-case}</mixed-case>
          </#if>
          <#if max\-length?has_content>
            <max-length>${max\-length}</max-length>
          </#if>
        </password-policy>
      </system-security>
    </config>
  </edit-config>
</rpc>



