<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <classifiers xmlns="urn:bbf:yang:bbf-qos-classifiers">
        <classifier-entry xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
         <name>policy-${igmp\-remarking\-policy\-name}_classifier</name>
         <filter-operation>match-all-filter</filter-operation>
         <match-criteria>
           <protocol>igmp</protocol>
         </match-criteria>
         <classifier-action-entry-cfg>
           <action-type>pbit-marking</action-type>
           <pbit-marking-cfg>
             <pbit-marking-list>
               <index>0</index>
               <pbit-value>${igmp\-pbit}</pbit-value>
             </pbit-marking-list>
           </pbit-marking-cfg>
         </classifier-action-entry-cfg>
        </classifier-entry>
      </classifiers>
      <policies xmlns="urn:bbf:yang:bbf-qos-policies">
        <policy xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
          <name>${igmp\-remarking\-policy\-name}</name>
          <classifiers>
            <name>policy-${igmp\-remarking\-policy\-name}_classifier</name>
          </classifiers>
        </policy>
      </policies>
    </config>
  </edit-config>
</rpc>
 