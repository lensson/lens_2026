                <template-ref>${tc6\-gemport\-set\-name}-${onu\-template\-cc\-name}-GEM6</template-ref>
                <#else>
                <template-ref>${onu\-template\-cc\-name}-GEM6</template-ref>
                </#if>
              </gemport>
              <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <#if tc7\-gemport\-set\-name?has_content>
                <template-ref>${tc7\-gemport\-set\-name}-${onu\-template\-cc\-name}-GEM7</template-ref>
                <#else>
                <template-ref>${onu\-template\-cc\-name}-GEM7</template-ref>
                </#if>
              </gemport>
            </gemports>
            <interfaces xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
            </interfaces>
          </template-parameters>
        </onu>
      </onus>
      </#if>
    </config>
  </edit-config>
</rpc>
