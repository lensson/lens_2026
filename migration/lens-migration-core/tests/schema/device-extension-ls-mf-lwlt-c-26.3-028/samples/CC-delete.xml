        <gemport xmlns:ns8="urn:ietf:params:xml:ns:netconf:base:1.0" ns8:operation="remove">
          <name>${cc\-name}-GEM7</name>
        </gemport>
      </gemports>
      </xpongemtcont>
      <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
        <ipv4-security-statistics xmlns="uri:http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipv4-address-spoofing-prevention">
          <interface xmlns:ns9="urn:ietf:params:xml:ns:netconf:base:1.0" ns9:operation="remove">
            <name>${cc\-name}-USER-VSI</name>
          </interface>
        </ipv4-security-statistics>
        <interface xmlns:ns10="urn:ietf:params:xml:ns:netconf:base:1.0" ns10:operation="delete">
          <name>${cc\-name}-NETWORK-VSI</name>
        </interface>
        <interface xmlns:ns11="urn:ietf:params:xml:ns:netconf:base:1.0" ns11:operation="delete">
          <name>${cc\-name}-USER-VSI</name>
        </interface>
      </interfaces>
      <#if onu\-template\-cc\-name?has_content && onu\-name?has_content>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <template-parameters xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/onus-from-template">
            <gemports>
              <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <#if tc0\-gemport\-set\-name?has_content>
                <template-ref>${tc0\-gemport\-set\-name}-${onu\-template\-cc\-name}-GEM0</template-ref>
                <#else>
                <template-ref>${onu\-template\-cc\-name}-GEM0</template-ref>
