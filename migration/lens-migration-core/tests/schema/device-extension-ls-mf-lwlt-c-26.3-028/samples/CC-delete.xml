<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <forwarding xmlns="urn:bbf:yang:bbf-l2-forwarding">
        <forwarders>
          <forwarder xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">
            <name>${cc\-name}-FWD</name>
          </forwarder>
        </forwarders>
      </forwarding>
      <xpongemtcont xmlns="urn:bbf:yang:bbf-xpongemtcont">
      <gemports>
        <gemport xmlns:ns1="urn:ietf:params:xml:ns:netconf:base:1.0" ns1:operation="remove">
          <name>${cc\-name}-GEM0</name>
        </gemport>
        <gemport xmlns:ns2="urn:ietf:params:xml:ns:netconf:base:1.0" ns2:operation="remove">
          <name>${cc\-name}-GEM1</name>
        </gemport>
        <gemport xmlns:ns3="urn:ietf:params:xml:ns:netconf:base:1.0" ns3:operation="remove">
          <name>${cc\-name}-GEM2</name>
        </gemport>
        <gemport xmlns:ns4="urn:ietf:params:xml:ns:netconf:base:1.0" ns4:operation="remove">
          <name>${cc\-name}-GEM3</name>
        </gemport>
        <gemport xmlns:ns5="urn:ietf:params:xml:ns:netconf:base:1.0" ns5:operation="remove">
          <name>${cc\-name}-GEM4</name>
        </gemport>
        <gemport xmlns:ns6="urn:ietf:params:xml:ns:netconf:base:1.0" ns6:operation="remove">
          <name>${cc\-name}-GEM5</name>
