                <#else>
                <template-ref>${onu\-template\-cc\-name}-GEM3</template-ref>
                </#if>
              </gemport>
              <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <#if tc4\-gemport\-set\-name?has_content>
                <template-ref>${tc4\-gemport\-set\-name}-${onu\-template\-cc\-name}-GEM4</template-ref>
                <#else>
                <template-ref>${onu\-template\-cc\-name}-GEM4</template-ref>
                </#if>
              </gemport>
              <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <#if tc5\-gemport\-set\-name?has_content>
                <template-ref>${tc5\-gemport\-set\-name}-${onu\-template\-cc\-name}-GEM5</template-ref>
                <#else>
                <template-ref>${onu\-template\-cc\-name}-GEM5</template-ref>
                </#if>
              </gemport>
              <gemport xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
