<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <multicast xmlns="urn:bbf:yang:bbf-mgmd">
        <mgmd>
          <multicast-vpn>
            <name>${vpn\-name}</name>
            <multicast-channel xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
              <name>${multicast\-channel\-name}</name>
            </multicast-channel>
<#if multicast\-package\-name?has_content>
            <multicast-package>
              <name>${multicast\-package\-name}</name>
              <multicast-channel-list  xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">${multicast\-channel\-name}</multicast-channel-list>
            </multicast-package>
</#if>
          </multicast-vpn>
        </mgmd>
      </multicast>
    </config>
  </edit-config>
</rpc>
