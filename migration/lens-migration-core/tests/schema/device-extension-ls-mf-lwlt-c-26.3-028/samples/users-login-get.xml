<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get>
    <filter type="subtree">
      <users xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-aaa">
        <user>
          <#if name?has_content>
            <name>${name}</name>
          </#if>
          <login>
            <failed-login/>
            <last-failed/>
            <last-login/>
            <last-password-changed/>
          </login>
        </user>
      </users>
    </filter>
  </get>
</rpc>



