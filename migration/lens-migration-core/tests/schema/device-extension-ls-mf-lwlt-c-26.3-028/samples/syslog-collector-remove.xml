<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="setSyslogSimpleFileCollector">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <syslog xmlns="urn:ietf:params:xml:ns:yang:ietf-syslog">
        <actions xmlns:nc="urn:ietf:params:xml:ns:netconf:base:1.0" nc:operation="remove">
        </actions>
      </syslog>
    </config>
  </edit-config>
</rpc>

