<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <action xmlns="urn:ietf:params:xml:ns:yang:1">
    <ipfix xmlns="urn:ietf:params:xml:ns:yang:ietf-ipfix-psamp">
      <exportingProcess>
        <name>${exporter\-name}</name>
        <destination>
          <name>${collector\-name}</name>
          <tcpExporter>
            <certificate xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipfix">
              <client-identity>
                <certificate>
                  <local-definition>
                    <install-hidden-key>
                      <private-key>${private\-key}</private-key>
                    </install-hidden-key>
                  </local-definition>
                </certificate>
              </client-identity>
            </certificate>
          </tcpExporter>
        </destination>
      </exportingProcess>
    </ipfix>
  </action>
</rpc>