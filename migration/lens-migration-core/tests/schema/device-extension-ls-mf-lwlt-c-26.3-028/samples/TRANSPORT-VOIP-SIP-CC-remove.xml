              </interface>
            </interfaces>
            <system>
              <server xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <name>pridns</name>
              </server>
              <server xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <name>backupdns</name>
