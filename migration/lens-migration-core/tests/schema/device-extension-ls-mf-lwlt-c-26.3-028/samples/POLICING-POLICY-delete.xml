<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <policies xmlns="urn:bbf:yang:bbf-qos-policies">
        <policy xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">
          <name>${policing\-policy\-name}</name>
        </policy>
      </policies>    	
      <classifiers xmlns="urn:bbf:yang:bbf-qos-classifiers">
        <classifier-entry xmlns:ns1="urn:ietf:params:xml:ns:netconf:base:1.0" ns1:operation="remove">
          <name>cls-ratelimit-${policing\-policy\-name}</name>
        </classifier-entry>
      </classifiers>
    </config>
  </edit-config>
</rpc>
