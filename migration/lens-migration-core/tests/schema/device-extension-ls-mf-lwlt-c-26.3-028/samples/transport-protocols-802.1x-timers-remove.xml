<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
<edit-config>
    <target>
      <running/>
   </target>
<config>
  <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
  <interface>
    <name>${user\-interface}</name>
      <pae xmlns="urn:ieee:std:802.1X:yang:ieee802-dot1x">
        <authenticator xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
        </authenticator>
	<ext-authenticator xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-802-dot1x-ext">
           <tx-period xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete"/>
           <initiate-authentication-request xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete"/>
           <handshake-enable xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete"/>
           <handshake-period xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete"/>
           <authentication-mode xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete"/>
           <#if authentication\-mode == "mac-based">
              <max-number-mac-addresses xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete"/>
           </#if>
           <interface-supplicant-timeout xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete"/>
	</ext-authenticator>
      </pae>
  </interface>
  </interfaces>
</config>
</edit-config>
</rpc>

