<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <trust-anchors xmlns="urn:ietf:params:xml:ns:yang:ietf-trust-anchors">
        <pinned-certificates xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
          <name>${certificate\-list\-name}</name>
          <pinned-certificate>
            <name>${certificate\-name}</name>
			      <cert>${certificate\-key}</cert>
          </pinned-certificate>
        </pinned-certificates>
      </trust-anchors>
    </config>
  </edit-config>
</rpc>

