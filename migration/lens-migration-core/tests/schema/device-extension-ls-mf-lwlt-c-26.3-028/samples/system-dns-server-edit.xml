    <target>
      <running/>
    </target>
    <config>
      <system xmlns="urn:ietf:params:xml:ns:yang:ietf-system">
        <dns-resolver>
          <server xmlns:nc="urn:ietf:params:xml:ns:netconf:base:1.0">
