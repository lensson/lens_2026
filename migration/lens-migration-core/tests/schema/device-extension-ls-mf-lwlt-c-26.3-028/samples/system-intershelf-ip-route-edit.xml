<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
<edit-config>
    <target>
      <running/>
    </target>
    <config>
    <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
      <interface>
        <name>${interface\-name}</name>
        <ipv4 xmlns="urn:ietf:params:xml:ns:yang:ietf-ip" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="replace">
          <address>
            <ip>${ipv4\-address}</ip>
            <netmask>${netmask}</netmask>
          </address>
        </ipv4>
        <control-protocol xmlns="urn:ietf:params:xml:ns:yang:nokia-ip-aug">
          <name>${control\-plane\-protocol\-name}</name>
        </control-protocol>
      </interface>
    </interfaces>
    <routing xmlns="urn:ietf:params:xml:ns:yang:ietf-routing">
        <control-plane-protocols>
          <control-plane-protocol>
            <type>static</type>
            <name>${control\-plane\-protocol\-name}</name>
            <default-route xmlns="urn:ietf:params:xml:ns:yang:nokia-routing-aug">false</default-route>
            <static-routes>
              <ipv4 xmlns="urn:ietf:params:xml:ns:yang:ietf-ipv4-unicast-routing">
                <route xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="replace">
                  <destination-prefix>${route\-dest\-prefix}</destination-prefix>
                  <next-hop>
                    <next-hop-address>${route\-next\-hop}</next-hop-address>
                  </next-hop>
                </route>
              </ipv4>
            </static-routes>
          </control-plane-protocol>
        </control-plane-protocols>
    </routing>
    </config>
  </edit-config>
</rpc>
