<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <ipfix xmlns="urn:ietf:params:xml:ns:yang:ietf-ipfix-psamp">
        <exportingProcess xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
          <name>${exporter\-name}</name>
          <exportMode>fallback</exportMode>
          <keepalives xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipfix">
            <idle-time>${idle\-time}</idle-time>
            <max-probes>${max\-probes}</max-probes>
            <probe-interval>${probe\-interval}</probe-interval>
          </keepalives>
        </exportingProcess>
      </ipfix>
    </config>
  </edit-config>
</rpc>
