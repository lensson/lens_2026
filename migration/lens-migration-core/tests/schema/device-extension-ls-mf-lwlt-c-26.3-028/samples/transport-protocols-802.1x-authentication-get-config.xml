<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get-config>
    <source>
      <running/>
    </source>
    <filter type="subtree">
      <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
        <interface>
          <name>${user\-interface}</name>
          <olt-v-enet xmlns="urn:bbf:yang:bbf-xponvani">
            <uni-name xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-olt-v-enet"></uni-name>
          </olt-v-enet>
          <pae xmlns="urn:ieee:std:802.1X:yang:ieee802-dot1x">
            <port-capabilities>
              <auth></auth>
            </port-capabilities>
            <ext-authenticator xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-802-dot1x-ext">
                <signalling-channel xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-802-dot1x-ext"></signalling-channel>
            </ext-authenticator>
          </pae>
        </interface>
      </interfaces>
    </filter>
  </get-config>
</rpc>
