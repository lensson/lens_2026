<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <lldp xmlns="urn:ieee:std:802.1AB:yang:ieee802-dot1ab-lldp-mounted">
              <port xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
                <name>${onu\-uni\-intf}</name>
                <dest-mac-address>${dest\-mac\-address}</dest-mac-address>
                <admin-status>${admin\-status}</admin-status>
                <message-fast-tx>${message\-fast\-tx}</message-fast-tx>
                <message-tx-hold-multiplier>${message\-tx\-hold\-multiplier}</message-tx-hold-multiplier>
                <message-tx-interval>${message\-tx\-interval}</message-tx-interval>
                <reinit-delay>${reinit\-delay}</reinit-delay>
                <tx-credit-max>${tx\-credit\-max}</tx-credit-max>
                <tx-fast-init>${tx\-fast\-init}</tx-fast-init>
              </port>
            </lldp>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>