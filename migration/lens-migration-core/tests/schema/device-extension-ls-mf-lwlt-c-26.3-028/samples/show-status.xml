<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get>
    <filter type="subtree">
      <protocol-tracing-state xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-protocol-tracing">
        <#if session\-name?has_content>
        <session>
            <name>${session\-name}</name>
        </session>
        </#if>
      </protocol-tracing-state>
    </filter>
  </get>
</rpc>
