<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0">
  <get>
    <filter type="subtree">
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <cfm xmlns="urn:ieee:std:802.1Q:yang:ieee802-dot1q-cfm-mounted">
              <maintenance-group>
                <maintenance-group-id>${maintenance\-group\-id}</maintenance-group-id>
                <md-id>${md\-id}</md-id>
                <ma-id>${ma\-id}</ma-id>
                <mep>
                  <mep-id>${mep\-id}</mep-id>
                </mep>
              </maintenance-group>
            </cfm>
          </root>
        </onu>
      </onus>
    </filter>
  </get>
</rpc>