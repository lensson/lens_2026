<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
<edit-config>
    <target>
      <running/>
   </target>
<config>
<onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
  <onu xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
    <name>${onu\-name}</name>
    <root>
      <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces-mounted">
        <interface>
          <name>${user\-interface}</name>
          <pae xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-802dot1x-mounted">
            <port-capabilities>
              <auth>${enable\-authentication}</auth>
            </port-capabilities>
          </pae>
        </interface>
      </interfaces>
    </root>
  </onu>
</onus>
</config>
</edit-config>
</rpc>

