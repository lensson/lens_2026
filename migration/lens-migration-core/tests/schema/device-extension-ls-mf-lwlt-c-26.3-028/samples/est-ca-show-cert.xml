<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <action xmlns="urn:ietf:params:xml:ns:yang:1">
    <certificate xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-certificate-management">
      <certificates-state>
        <est-certificates>
          <est-profiles>
            <profile>${profile\-name}</profile>
              <ca-certificates>
                <ca-certificate>
                  <cert>${certificate\-name}</cert>
                  <show-cert>
                    <format>${format}</format>
                  </show-cert>
                </ca-certificate>
              </ca-certificates>
          </est-profiles>
        </est-certificates>
      </certificates-state>
    </certificate>
  </action>
</rpc>