<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get-config>
    <source>
      <running/>
    </source>
    <filter type="subtree">
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <hardware xmlns="urn:ietf:params:xml:ns:yang:ietf-hardware-mounted">
              <component xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="get">
                <name>pots-port-${pots\-port\-hw\-number}</name>
              </component>
            </hardware>
            <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces-mounted">
              <interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="get">
                <name>${voip\-uni\-name}</name>
              </interface>
            </interfaces>
            <sip-signaling xmlns="urn:bbf:yang:bbf-sip-voip-mounted">
              <sip-terminations>
                <sip-termination xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="get">
                  <sip-user-name>${voip\-uni\-name}</sip-user-name>
                </sip-termination>
              </sip-terminations>
            </sip-signaling>
            <pots-interworking-nodes xmlns="urn:bbf:yang:bbf-sip-voip-mounted">
              <pots-interworking xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="get">
                <name>${voip\-uni\-name}</name>
              </pots-interworking>
            </pots-interworking-nodes>
          </root>
        </onu>
      </onus>
    </filter>
  </get-config>
</rpc>