<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <hardware xmlns="urn:ietf:params:xml:ns:yang:ietf-hardware-mounted">
              <component xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <name>pots-port-${pots\-port\-hw\-number}</name>
                <class xmlns:bbf-hwt="urn:bbf:yang:bbf-hardware-types">bbf-hwt:transceiver-link</class>
              </component>
            </hardware>
            <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces-mounted">
              <interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <name>${voip\-uni\-name}</name>
                <type xmlns:ianaift="urn:ietf:params:xml:ns:yang:iana-if-type-mounted">ianaift:voiceFXS</type>
              </interface>
            </interfaces>
            <sip-signaling xmlns="urn:bbf:yang:bbf-sip-voip-mounted">
              <sip-terminations>
                <sip-termination xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                  <sip-user-name>${voip\-uni\-name}</sip-user-name>
                </sip-termination>
              </sip-terminations>
              <voip-service-gateways>
                <voip-service-gateway>
                  <name>agent</name>
                  <sip-terminations xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">${voip\-uni\-name}</sip-terminations>
                </voip-service-gateway>
              </voip-service-gateways>
            </sip-signaling>
            <pots-interworking-nodes xmlns="urn:bbf:yang:bbf-sip-voip-mounted">
              <pots-interworking xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">
                <name>${voip\-uni\-name}</name>
              </pots-interworking>
            </pots-interworking-nodes>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>