<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <tca-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-hardware-profiles-mounted">
              <pm-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-hardware-pm-threshold-profiles-mounted">
                <moca-interface-tca-profile xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-moca-pm-threshold-profiles-mounted" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
                  <name>${moca\-interface\-tca\-profile}</name>
<#if in\-errored\-threshold?has_content>
                  <in-errored-threshold>${in\-errored\-threshold}</in-errored-threshold>
</#if>
<#if in\-errored\-and\-missed\-threshold?has_content>
                  <in-errored-and-missed-threshold>${in\-errored\-and\-missed\-threshold}</in-errored-and-missed-threshold>
</#if>
                </moca-interface-tca-profile>
              </pm-profiles>
            </tca-profiles>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>