<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <tca-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-hardware-profiles-mounted">
              <pm-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-hardware-pm-threshold-profiles-mounted">
                <ethernet-frame-error-extended-profile xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-ethernet-pm-threshold-profiles-mounted" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
                  <name>${ethernet\-frame\-error\-extended\-profile}</name>
<#if in\-drop\-frames\-threshold?has_content>
                  <in-drop-frames-threshold>${in\-drop\-frames\-threshold}</in-drop-frames-threshold>
</#if>
<#if out\-drop\-frames\-threshold?has_content>
                  <out-drop-frames-threshold>${out\-drop\-frames\-threshold}</out-drop-frames-threshold>
</#if>
<#if in\-drop\-octets\-threshold?has_content>
                  <in-drop-octets-threshold>${in\-drop\-octets\-threshold}</in-drop-octets-threshold>
</#if>
                </ethernet-frame-error-extended-profile>
              </pm-profiles>
            </tca-profiles>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>