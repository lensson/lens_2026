<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <multicast xmlns="urn:bbf:yang:bbf-mgmd-mounted">
              <mgmd>
                <multicast-vpn>
                  <name>${vpn\-name}</name>
                  <multicast-channel xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">
                    <name>${multicast\-channel\-name}</name>
                  </multicast-channel>
<#if multicast\-package\-name?has_content>
                  <multicast-package>
                    <name>${multicast\-package\-name}</name>
                    <multicast-channel-list xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">${multicast\-channel\-name}</multicast-channel-list>
                  </multicast-package>
</#if>
                </multicast-vpn>
              </mgmd>
            </multicast>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>