<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <tca-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-hardware-profiles-mounted">
              <pm-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-hardware-pm-threshold-profiles-mounted">
                <gem-frame-error-profile xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-xponani-pm-threshold-profiles-mounted" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
                  <name>${gem\-frame\-error\-profile}</name>
<#if in\-lost\-gem\-frames\-threshold?has_content>
                  <in-lost-gem-frames-threshold>${in\-lost\-gem\-frames\-threshold}</in-lost-gem-frames-threshold>
</#if>
<#if out\-lost\-gem\-frames\-threshold?has_content>
                  <out-lost-gem-frames-threshold>${out\-lost\-gem\-frames\-threshold}</out-lost-gem-frames-threshold>
</#if>
<#if bad\-gem\-header\-error\-threshold?has_content>
                  <bad-gem-header-error-threshold>${bad\-gem\-header\-error\-threshold}</bad-gem-header-error-threshold>
</#if>
                </gem-frame-error-profile>
              </pm-profiles>
            </tca-profiles>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>