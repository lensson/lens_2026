<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
    <get-config>
        <source>
            <running/>
        </source>
        <filter type="subtree">
      <multicast xmlns="urn:bbf:yang:bbf-mgmd">
        <mgmd>
<#if vpn\-name?has_content>
          <multicast-vpn>
              <name>${vpn\-name}</name>
          </multicast-vpn>
<#elseif detailed\-output == false>
          <multicast-vpn>
                <name/>
          </multicast-vpn>
<#else>
          <multicast-vpn/>
</#if>
        </mgmd>
      </multicast>
    </filter>
  </get-config>
</rpc>
