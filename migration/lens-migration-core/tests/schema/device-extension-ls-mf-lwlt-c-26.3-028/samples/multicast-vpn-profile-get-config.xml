<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get-config>
    <source>
      <running/>
    </source>
    <filter type="subtree">
      <multicast xmlns="urn:bbf:yang:bbf-mgmd">
        <mgmd>
<#if vpn\-profile\-name?has_content>
          <multicast-proxy-profile>
              <name>${vpn\-profile\-name}</name>
          </multicast-proxy-profile>
<#elseif detailed\-output == false>
          <multicast-proxy-profile>
                <name/>
          </multicast-proxy-profile>
<#else>
          <multicast-proxy-profile/>
</#if>
        </mgmd>
      </multicast>
    </filter>
  </get-config>
</rpc>
