<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <get>
    <filter type="subtree">
      <licensing-state xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-licensing-app">
        <#if feature\-code?has_content>
        <features>
          <feature-code>${feature\-code}</feature-code>
        </features>
        </#if>
      </licensing-state>
    </filter>
  </get>
</rpc>
