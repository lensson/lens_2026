<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
     <config>
      <ber-tca-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ber-tca-profiles">
