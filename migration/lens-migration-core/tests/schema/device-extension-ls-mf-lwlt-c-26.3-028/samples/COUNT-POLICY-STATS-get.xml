<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
    <get>
        <filter type="subtree">
            <interfaces-state xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces">
                <interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="get">
                    <name>${interface\-name}</name>
                    <qos-policies xmlns="urn:bbf:yang:bbf-qos-policies-state">
                        <ingress>
                        <policy>
                            <name>${ingress\-policy\-name}</name>
                            <classifier>
                                <name>${ingress\-classifier\-name}</name>
                                <index xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-flow-statistics"/>
                                    <flow xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-flow-statistics">
                                        <statistics/>
                                    </flow>
                            </classifier>
                        </policy>
                        </ingress>
                        <egress>
                        <policy>
                            <name>${egress\-policy\-name}</name>
                            <classifier>
                                <name>${egress\-classifier\-name}</name>
                                <index xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-flow-statistics"/>
                                    <flow xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-flow-statistics">
                                        <statistics/>
                                    </flow>
                            </classifier>
                        </policy>
                        </egress>
                    </qos-policies>
                </interface>
            </interfaces-state>
        </filter>
    </get>
</rpc>

