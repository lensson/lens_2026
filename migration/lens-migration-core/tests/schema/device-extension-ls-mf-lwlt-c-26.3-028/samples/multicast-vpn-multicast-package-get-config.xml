<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
    <get-config>
        <source>
            <running/>
        </source>
        <filter type="subtree">
            <multicast xmlns="urn:bbf:yang:bbf-mgmd">
                <mgmd>
                    <multicast-vpn>
                        <name>${vpn\-name}</name>
<#if multicast\-package\-name?has_content>
                        <multicast-package>
                            <name>${multicast\-package\-name}</name>
                        </multicast-package>
<#elseif detailed\-output == false>
                        <multicast-package>
                            <name/>
                        </multicast-package>
<#else>
                        <multicast-package/>
</#if>
                    </multicast-vpn>
                </mgmd>
            </multicast>
        </filter>
    </get-config>
</rpc>
