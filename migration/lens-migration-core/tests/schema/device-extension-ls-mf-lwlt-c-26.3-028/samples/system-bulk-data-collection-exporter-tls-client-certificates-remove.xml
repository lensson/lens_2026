<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <ipfix xmlns="urn:ietf:params:xml:ns:yang:ietf-ipfix-psamp">
        <exportingProcess>
          <name>${exporter\-name}</name>
          <destination>
            <name>${collector\-name}</name>
            <tcpExporter>
              <certificate xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipfix">
                <client-identity>
                  <certificate>
                    <local-definition>
                      <cert xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove">${client\-certificate}</cert>
                    </local-definition>
                  </certificate>
                </client-identity>
              </certificate>
            </tcpExporter>
          </destination>
        </exportingProcess>
      </ipfix>
    </config>
  </edit-config>
</rpc>