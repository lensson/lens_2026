<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <system xmlns="urn:ietf:params:xml:ns:yang:ietf-system">
        <radius>
          <server xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">
            <name>${auth\-server1\-name}</name>
          </server>
          <#if auth\-server2\-name?has_content>
            <server xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">
              <name>${auth\-server2\-name}</name>
            </server>
          </#if>
          <#if acc\-server1\-name?has_content>
            <server xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">
              <name>${acc\-server1\-name}</name>
            </server>
          </#if>
          <#if acc\-server2\-name?has_content>
            <server xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="delete">
              <name>${acc\-server2\-name}</name>
            </server>
          </#if>
        </radius>
      </system>
    </config>
  </edit-config>
</rpc>

