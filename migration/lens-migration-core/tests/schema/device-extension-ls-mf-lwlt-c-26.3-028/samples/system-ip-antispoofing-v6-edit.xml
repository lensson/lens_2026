<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <ipv6-antispoofing-system xmlns="uri:http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipv6-address-spoofing-prevention" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
          <#if on\-admindown?has_content>
            <clear-dhcp-learned-ipv6-addresses-on-admindown>${on\-admindown}</clear-dhcp-learned-ipv6-addresses-on-admindown>
          </#if>
          <#if on\-operdown?has_content>
            <clear-dhcp-learned-ipv6-addresses-on-operdown>${on\-operdown}</clear-dhcp-learned-ipv6-addresses-on-operdown>
          </#if>
          <#if tca\-in\-ipv6\-packet\-discards?has_content>
            <tca-in-ipv6-packet-discards>${tca\-in\-ipv6\-packet\-discards}</tca-in-ipv6-packet-discards>
          </#if>
      </ipv6-antispoofing-system>
      <#if prefix\-mode?has_content>
        <ipv6-antispoof-prefix-mode xmlns="uri:http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-ipv6-address-spoofing-prevention" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
          <prefix-mode>${prefix\-mode}</prefix-mode>
        </ipv6-antispoof-prefix-mode>
      </#if>
    </config>
  </edit-config>
</rpc>
