<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <interfaces xmlns="urn:ietf:params:xml:ns:yang:ietf-interfaces-mounted">
              <interface xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="merge">
                <name>${uni\-name}</name>
                <type xmlns:ianaift-mounted="urn:ietf:params:xml:ns:yang:iana-if-type-mounted">ianaift-mounted:ethernetCsmacd</type>
                <port-layer-if xmlns="urn:bbf:yang:bbf-interface-port-reference-mounted">${uni\-port\-layer\-if\-name}</port-layer-if>
                <ethernet xmlns="urn:ieee:params:xml:ns:yang:ethernet-mounted">
                  <auto-negotiation>
                    <status>${autoneg\-status}</status>
                  </auto-negotiation>
                </ethernet>
                <ptp-port xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-conf-clock-ptp-mounted">
                  <#if enable?has_content>
                    <enable>${enable}</enable>
                  </#if>
                  <#if profile\-type == 'g8275dot1'>
                    <profile-ref-8275dot1>${profile\-name}</profile-ref-8275dot1>
                  </#if>
                  <#if profile\-type == 'ccsa'>
                    <profile-ref-ccsa>${profile\-name}</profile-ref-ccsa>
                  </#if>
                </ptp-port>
              </interface>
            </interfaces>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>
