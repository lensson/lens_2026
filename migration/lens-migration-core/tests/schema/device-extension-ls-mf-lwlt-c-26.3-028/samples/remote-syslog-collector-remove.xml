<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="setSyslogRemoteCollector">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <syslog xmlns="urn:ietf:params:xml:ns:yang:ietf-syslog">
        <actions>
          <remote>
            <destination  xmlns:nc="urn:ietf:params:xml:ns:netconf:base:1.0" nc:operation="remove">
              <name>${syslog\-collector\-name}</name>
            </destination>
          </remote>
        </actions>
      </syslog>
    </config>
  </edit-config>
</rpc>
