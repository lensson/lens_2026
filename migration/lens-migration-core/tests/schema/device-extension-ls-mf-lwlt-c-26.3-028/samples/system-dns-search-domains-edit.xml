<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <system xmlns="urn:ietf:params:xml:ns:yang:ietf-system">
        <dns-resolver>
          <search>${domain1}</search>
          <#if domain2?has_content>
            <search>${domain2}</search>
          </#if>
          <#if domain3?has_content>
            <search>${domain3}</search>
          </#if>
          <options>
            <timeout>${timeout}</timeout>
            <attempts>${attempts}</attempts>
          </options>
        </dns-resolver>
      </system>
    </config>
  </edit-config>
</rpc>
