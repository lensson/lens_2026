<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
 <edit-config>
   <target>
     <running/>
   </target>
   <config>
     <system-security xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-aaa">
       <client-authentication>
            <supported-authentication-methods>
              <#if authentication\-method == 'password'>
                <password xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="remove"/>
              </#if>
            </supported-authentication-methods>
       </client-authentication>
     </system-security>
   </config>
 </edit-config>
</rpc>
