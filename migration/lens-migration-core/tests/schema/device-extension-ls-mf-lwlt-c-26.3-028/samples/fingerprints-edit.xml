<rpc
    xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
    <edit-config>
        <target>
            <running/>
        </target>
        <config>
            <netconf-server
                xmlns="urn:ietf:params:xml:ns:yang:ietf-netconf-server">
                <call-home>
                    <netconf-client>
                        <name>${netconf\-client\-name}</name>
                        <endpoints>
                            <endpoint>
                                <name>certificate_endpoint</name>
                                <tls>
                                    <client-auth>
                                        <cert-maps>
                                            <cert-to-name>
                                                <id> ${id} </id>
                                                <fingerprint>  ${fingerprint}  </fingerprint>
                                                <map-type>   ${map\-type}</map-type>
                                                    <#if name?has_content>
                                                    <name> ${name} </name>
                                                    </#if>
                                            </cert-to-name>
                                        </cert-maps>
                                    </client-auth>
                                </tls>
                            </endpoint>
                        </endpoints>
                    </netconf-client>
                </call-home>
            </netconf-server>
        </config>
    </edit-config>
</rpc>