<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
    <action xmlns="urn:ietf:params:xml:ns:yang:1">
        <syslog xmlns="urn:ietf:params:xml:ns:yang:ietf-syslog">
            <actions>
                <remote>
                    <destination>
                        <name>${syslog\-collector\-name}</name>
                        <tls>
                            <client-identity>
                                <certificate>
                                    <local-definition>
                                        <install-hidden-key>
                                            <private-key>${private\-key}</private-key>
                                        </install-hidden-key>
                                    </local-definition>
                                </certificate>
                            </client-identity>
                        </tls>
                    </destination>
                </remote>
            </actions>
        </syslog>
    </action>
</rpc>