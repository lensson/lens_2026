<rpc xmlns="urn:ietf:params:xml:ns:netconf:base:1.0" message-id="1">
  <edit-config>
    <target>
      <running/>
    </target>
    <config>
      <onus xmlns="urn:bbf:params:xml:ns:yang:bbf-fiber-onu-emulated-mount">
        <onu>
          <name>${onu\-name}</name>
          <root>
            <tca-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-hardware-profiles-mounted">
              <pm-profiles xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-hardware-pm-threshold-profiles-mounted">
                <ethernet-frame-error-profile xmlns="http://www.nokia.com/Fixed-Networks/BBA/yang/nokia-sdan-ethernet-pm-threshold-profiles-mounted" xmlns:ns0="urn:ietf:params:xml:ns:netconf:base:1.0" ns0:operation="create">
                  <name>${ethernet\-frame\-error\-profile}</name>
<#if drop\-events\-threshold?has_content>
                  <drop-events-threshold>${drop\-events\-threshold}</drop-events-threshold>
</#if>
<#if eth\-crc\-tca\-threshold?has_content>
                  <crc-err-pkts-threshold>${eth\-crc\-tca\-threshold}</crc-err-pkts-threshold>
</#if>
<#if undersize\-pkts\-threshold?has_content>
                  <undersize-pkts-threshold>${undersize\-pkts\-threshold}</undersize-pkts-threshold>
</#if>
<#if oversize\-pkts\-threshold?has_content>
                  <oversize-pkts-threshold>${oversize\-pkts\-threshold}</oversize-pkts-threshold>
</#if>
                </ethernet-frame-error-profile>
              </pm-profiles>
            </tca-profiles>
          </root>
        </onu>
      </onus>
    </config>
  </edit-config>
</rpc>