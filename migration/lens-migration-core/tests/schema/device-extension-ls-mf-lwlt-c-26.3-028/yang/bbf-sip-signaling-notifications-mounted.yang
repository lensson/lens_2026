    description
      "Initial revision.
       * Approval Date:    see revision date above.
       * Publication Date: 2020-03-06.";
    reference
      " ";
  }
  
   identity sip-voip-vag-alarm-notification {
	description
	  "Base identity for the per-vag related SIP voip alarm 
	   notifications.
	   This identity is abstract and is not to be used for any 
	   SIP VoIP alarm notification.";
  }

  identity sip-voip-vag-inform-notification {
	description
	  "Base identity for the per-vag related SIP voip 
	   inform notifications.
	   // This identity is abstract and is not to be used for any 
	   SIP VoIP inform notification.";
  }
  
  identity sip-vag-ssp-file-not-found {
	base sip-voip-vag-alarm-notification;
	description
	  "A pre-config file with the configured name and/or version
	   is not found.";
  }
  
  
  identity sip-voip-vsg-alarm-notification {
	description
	  "Base identity for the per-vsg related SIP voip alarm 
	   notifications.
	   This identity is abstract and is not be used for any 
	   SIP VoIP alarm notification.";
  }

  identity sip-voip-vsg-inform-notification {
	description
	  "Base identity for the per-vsg related SIP voip 
	   inform notifications.
	   This identity is abstract and is not to be used for any 
	   SIP VoIP inform notification.";
  }

  identity sip-voip-vsp-alarm-notification {
	description
	  "Base identity for the per-vsp related SIP voip alarm 
	   notifications.
	   This identity is abstract and is not to be used for any 
	   SIP VoIP alarm notification.";
  }

  identity sip-voip-vsp-inform-notification {
	description
	  "Base identity for the per-vsp related SIP voip 
	   inform notifications.
	   This identity is abstract and is not to be used for any 
	   SIP VoIP inform notification.";
  }
  
  identity sip-termination-alarm-notification {
	description
	  "Base identity for the sip termination related alarm
	   notifications.
	   This identity is abstract and is not to be used for any 
	   alarm notification.";
  }

  identity sip-termination-inform-notification {
	description
	  "Base identity for the sip termination related 
	   inform notifications.
	   This identity is abstract and is not to be used for any 
	   alarm notification.";
  }
  
  identity sip-ua-alarm-notification {
	description
	  "Base identity for the SIP user-agent related alarm
	   notifications.
	   This identity is abstract and is not to be used for any 
	   alarm notification.";
  }

  identity sip-ua-inform-notification {
	description
	  "Base identity for the SIP user-agent related 
	   inform notifications.
	   This identity is abstract and is not to be used for any 
	   alarm notification.";
  }
  
 
  identity sip-ua-no-reply-from-dhcpv4-server {
	base sip-ua-alarm-notification;
	description
		"None of the DHCP servers reply.";
	}
	
/*
