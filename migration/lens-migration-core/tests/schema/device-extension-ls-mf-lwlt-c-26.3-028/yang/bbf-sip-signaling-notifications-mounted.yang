	description
		"The DHCPv4 server did not return a first hop SIP server
		address as a response to the requested option 120 or the
		DHCPv4 server returned an invalid first hop SIP server 
		address as a response to the requested option 120.";
	}

  identity sip-vsp-missing-first-hop-sip-server-configuration {
	base sip-voip-vsp-alarm-notification;
	description
		"No first hop SIP server found in the configuration data.";
	}

  identity sip-vsp-no-reply-from-first-hop-sip-server {
	base sip-voip-vsp-alarm-notification;
	description
