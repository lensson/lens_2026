  identity sip-vsp-bad-digitmap {
	base sip-voip-vsp-alarm-notification;
	description
		"The configured digitmap is not fully correct and is 
		 therefore not usable.";
	}

  identity sip-vag-missing-first-hop-sip-server-configuration {
	base sip-voip-vag-alarm-notification;
	description
	  "No first hop SIP server found in the configuration data.";
  }

  identity sip-vag-no-reply-from-first-hop-sip-server {
	base sip-voip-vag-alarm-notification;
	description
	  "None of the first hop SIP servers reply to a request.";
  }

  identity sip-vag-no-first-hop-sip-server-reachable {
	base sip-voip-vag-alarm-notification;
	description
      "None of the first hop SIP servers are reachable.";
  }

  identity sip-vag-transport-protocol-mismatch {
	base sip-voip-vag-alarm-notification;
	description
	  "There is a transport protocol mismatch between the transport
	   protocols supported by the SIP Forwarder (User Agent) and the
	   transport protocols supported by the first hop SIP server.";
  } 

  identity sip-vag-first-hop-sip-server-failover {
	base sip-voip-vag-alarm-notification;
	description
	  "A first hop SIP server fail-over happened, from the primary
	   first hop SIP server to a secondary first hop SIP server or
	   from a secondary first hop SIP server to another secondary 
	   first hop SIP server.";
  }

  identity sip-vag-first-hop-sip-server-failback {
	base sip-voip-vag-alarm-notification;
	description
	  "A first hop SIP server fail-back happened, from a secondary 
	   first hop SIP server to the primary first hop SIP server.";
  }

  identity sip-vag-primary-first-hop-sip-server-substitution {
	base sip-voip-vag-alarm-notification;
	description
	  "A new primary first hop SIP server was identified. A fail-over
   	   happened from the previously addressed primary first hop SIP 
	   server to the newly identified primary first hop SIP server.";
	}

  identity sip-termination-register-unresolved-dn {
	base sip-termination-alarm-notification;
	description
	  "The SIP register request has failed because of a domain 
	   name that could not be resolved.";
	}

  identity sip-termination-register-authorisation-failure {
	base sip-termination-alarm-notification;
	description
	  "The SIP register request has failed because of an  
	   authorisation failure.";
  }

  identity sip-termination-register-request-timeout {
	base sip-termination-alarm-notification;
	description
	  "The SIP register request has failed because of a SIP
	   request timeout.";
	}

  identity sip-termination-register-error-response {
	base sip-termination-alarm-notification;
	description
	  "The SIP register request has been replied by the 
	   SIP register server with an error response.";
  }

  identity sip-termination-invite-unresolved-dn {
	base sip-termination-alarm-notification;
	description
	  "The SIP invite request has failed because of a domain 
	   name that could not be resolved.";
  }

  identity sip-termination-invite-authorisation-failure {
	base sip-termination-alarm-notification;
	description
	  "The SIP invite request has failed because of an  
	   authorisation failure.";
  }

  identity sip-termination-invite-request-timeout {
	base sip-termination-alarm-notification;
	description
	  "The SIP invite request has failed because of a SIP
	   request timeout.";
  }

  identity sip-termination-invite-error-response {
	base sip-termination-alarm-notification;
	description
	  "The SIP invite request has been replied by the 
	   first hop SIP server with an error response.";
  }

  identity sip-termination-subscribe-unresolved-dn {
	base sip-termination-alarm-notification;
	description
	  "The SIP subscribe request has failed because of a domain 
	   name that could not be resolved.";
  }

  identity sip-termination-subscribe-authorisation-failure {
	base sip-termination-alarm-notification;
	description
	  "The SIP subscribe request has failed because of an  
	   authorisation failure.";
	}

  identity sip-termination-subscribe-request-timeout {
	base sip-termination-alarm-notification;
	description
	  "The SIP subscribe request has failed because of a SIP
	   request timeout.";
  }

  identity sip-termination-subscribe-error-response {
	base sip-termination-alarm-notification;
	description
	  "The SIP subscribe request has been replied by the 
	   application SIP server with an error response.";
  }

  identity sip-termination-subscribe-refresh-timeout {
	base sip-termination-alarm-notification;
	description
	  "The SIP subscribe refresh request has failed because
	   of a SIP request timeout.";
  }

  identity sip-termination-emergency-call-ongoing {
	base sip-termination-inform-notification;
	description
	  "The SIP termination is actually involved in an emergency
	   call.";
  }

  grouping sip-ua-notifications {
      notification sip-ua-no-reply-from-dhcpv4-server {
          if-feature specific-notifications;
	  description
	    "No reply received to the DHCP Discover request.";
// BBOG: redundant with notification name unless more identities will be defined
//       with this base.
//       If there will be only 1 identity then this leaf is redundant with the
//       notification name and can be removed
	  leaf sip-ua-alarm-identity {
	    type identityref {
	      base sip-ua-no-reply-from-dhcpv4-server;
	    }
	    mandatory true;
	    description
	      "A unique identity associated with this notification.";
	  }
          leaf network-element-name {
              type bbf-yang:string-ascii64;
              description
                  "The name of the network element (LT board) at
	           which the SIP user agent is hosted.";
          }
      }
      notification sip-ua-notification {
          if-feature generic-notification;
	  description
	    "Generic SIP User Agent notification to inform about an
             occured event";
	  leaf sip-ua-alarm-identity {
	    type identityref {
	      base sip-ua-alarm-notification;
	    }
	    mandatory true;
	    description
	      "A unique identity associated with the event occurence";
	  }
          leaf network-element-name {
              type bbf-yang:string-ascii64;
              description
                  "The name of the network element (LT board) at
	           which the SIP user agent is hosted.";
          }
      }
  }

  grouping sip-vsp-notifications {
    notification sip-vsp-bad-digitmap {
          if-feature specific-notifications;
	  description
	    "The configured digitmap is not fully correct and is 
		 therefore not usable.";
// BBOG: redundant with notification name unless more identities will be defined
//       with this base.
//       If there will be only 1 identity then this leaf is redundant with the
//       notification name and can be removed
	  leaf vsp-alarm-identity {
	    type identityref {
	      base sip-vsp-bad-digitmap;
	    }
	    mandatory true;
	    description
	      "A unique identity associated with this notification.";
	  }
    }

    notification sip-vsp-notification {
          if-feature generic-notification;
	  description
	    "Generic SIP VSP notification to inform about an
             occured event";
	  leaf sip-vsp-alarm-identity {
	    type identityref {
	      base sip-voip-vsp-alarm-notification;
	    }
	    mandatory true;
	    description
	      "A unique identity associated with the event occurence";
	  }
      }
  }
  
  grouping sip-vag-notifications {
    notification sip-vag-ssp-file-not-found {
      description
	    "The configured sip service pre-config file is not found.";
// BBOG: redundant with notification name unless more identities will be defined
//       with this base.
//       If there will be only 1 identity then this leaf is redundant with the
//       notification name and can be removed
      leaf vag-alarm-identity {
	    type identityref {
	      base sip-vag-ssp-file-not-found;
	    }
	    mandatory true;
	    description
	      "A unique identity associated with this notification.";
      }
      leaf call-flow-file-id { 
        type bbf-yang:string-ascii64;
        description
          "The identity of the sip service profile configuration 
	      file to be used for this VAG.";
      }
      leaf call-flow-file-version {	       
        type string {length "1..32";}
        description
          "The version of the sip service profile configuration
           file.";
      }	
    }	

    notification sip-vag-transport-protocol-mismatch {
	  description
	    "There is a transport protocol mismatch between the transport
	     protocols supported by the SIP Forwarder (User Agent) and the
	     transport protocols supported by the first hop SIP server.";
// BBOG: redundant with notification name unless more identities will be defined
//       with this base.
//       If there will be only 1 identity then this leaf is redundant with the
//       notification name and can be removed
	  leaf vag-alarm-identity {
	    type identityref {
	      base sip-vag-transport-protocol-mismatch;
	    }
	    mandatory true;
	    description
	      "A unique identity associated with this notification.";
	  }
    }

    notification sip-vag-first-hop-sip-server-failover {
	  description
	  "A first hop SIP server fail-over happened.";
// BBOG: redundant with notification name unless more identities will be defined
//       with this base.
//       If there will be only 1 identity then this leaf is redundant with the
//       notification name and can be removed
	  leaf vag-inform-identity {
	    type identityref {
	      base sip-vag-first-hop-sip-server-failover;
	    }
	    mandatory true;
	    description
	      "A unique identity associated with this inform 
		   notification.";
	  }
	  leaf failed-first-hop-sip-server-name {
	    type bbf-yang:string-ascii64;
	    mandatory true;
	    description
	      "The name of the failed first hop SIP server.";
	  }
	  leaf failed-first-hop-sip-server-address {
	    type inet:host;
	    mandatory true;
            description
        	"The address of the failed first hop SIP server.";
	  }
	  leaf selected-first-hop-sip-server-name {
	    type bbf-yang:string-ascii64;
	    mandatory true;
	    description
	      "The name of the newly selected first hop SIP server.";
	  }
	  leaf selected-first-hop-sip-server-address {
	    type inet:host;
	    mandatory true;
            description
        	"The address of the newly selected first hop SIP server.";
	  }
    }
  
    notification sip-vag-first-hop-sip-server-failback {
	  description
	  "A first hop SIP server fail-back happened.";
// BBOG: redundant with notification name unless more identities will be defined
//       with this base.
//       If there will be only 1 identity then this leaf is redundant with the
//       notification name and can be removed
	  leaf vag-inform-identity {
	    type identityref {
	      base sip-vag-first-hop-sip-server-failback;
	    }
	    mandatory true;
	    description
	      "A unique identity associated with this inform 
		   notification.";
	  }	   	
	  leaf secondary-first-hop-sip-server-name {
	    type bbf-yang:string-ascii64;
	    mandatory true;
	    description
	      "The name of the secondary first hop SIP server that has 
	       been left behind.";
	  }
	  leaf secondary-first-hop-sip-server-address {
	    type inet:host;
	    mandatory true;
            description
        	"The address of the secondary first hop SIP server that has
	       been left behind.";
	  }
	  leaf primary-first-hop-sip-server-name {
	    type bbf-yang:string-ascii64;
	    mandatory true;
	    description
	      "The name of the primary first hop SIP server.";
	  }
	  leaf primary-first-hop-sip-server-address {
	    type inet:host;
	    mandatory true;
            description
        	"The address of the primary first hop SIP server.";
	  }
    }

    notification sip-vag-primary-first-hop-sip-server-substitution {
	  description
	    "A primary first hop SIP server substitution happened.";
// BBOG: redundant with notification name unless more identities will be defined
//       with this base.
//       If there will be only 1 identity then this leaf is redundant with the
//       notification name and can be removed
	  leaf vag-inform-identity {
	    type identityref {
	      base sip-vag-primary-first-hop-sip-server-substitution;
	    }
	    mandatory true;
	    description
	      "A unique identity associated with this inform 
	  	 notification.";
	  }	  
	  leaf old-primary-first-hop-sip-server {
	    type bbf-yang:string-ascii64;
	    mandatory true;
	    description
	      "The name of the former primary first hop SIP server.";
	  }
	  leaf old-primary-first-hop-sip-server-address {
	    type inet:host;
	    mandatory true;
            description
      	        "The address of the former primary first hop SIP server.";
	  }    
	  leaf new-primary-first-hop-sip-server-name {
	    type bbf-yang:string-ascii64;
	    mandatory true;
	    description
	      "The name of the new primary first hop SIP server.";
	  }
	  leaf new-primary-first-hop-sip-server-address {
	    type inet:host;
	    mandatory true;
            description
        	"The address of the new primary first hop SIP server.";
	  }
    }
  }	

