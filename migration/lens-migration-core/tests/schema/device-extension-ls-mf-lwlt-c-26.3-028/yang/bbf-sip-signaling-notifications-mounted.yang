    notification sip-termination-alarm-notification {
        if-feature generic-notification;
	description
	  "The SIP register request has failed because of a domain 
	   name that could not be resolved.";
	leaf sip-termination-alarm-identity {
	  type identityref {
	    base sip-termination-alarm-notification;
	  }
	  mandatory true;
	  description
	    "A unique identity associated with this notification.";
	}
    }

    notification sip-termination-inform-notification {
        if-feature generic-notification;
	description
	  "The SIP register request has failed because of a domain 
	   name that could not be resolved.";
	leaf sip-termination-alarm-identity {
	  type identityref {
	    base sip-termination-inform-notification;
	  }
	  mandatory true;
	  description
	    "A unique identity associated with this notification.";
	}
    }
