  grouping file-category-techsupport-group {
    description "File category techsupport group";
    list category {
      key category-type;
      min-elements 1;
      max-elements 1;
      description "Category list.";

      leaf category-type {
        type file-category-type;
        description "Category type.";
      }

      uses file-category-common-techsupport-params;
    }
  }

  grouping file-category-group {
    description "File category group.";
    list category {
      key category-type;
      min-elements 1;
      max-elements 1;
      description "Category list.";

      leaf category-type {
        type file-category-type;
        description "Category type.";
      }

      uses file-category-common-params;

    }
  }

  container file-transfer {
    description
      "File transfer configuration parameters.";

    container file-transfer-control {
      description
        "Specifies the list of file transfer protocols to be enabled in the system.
         By default, HTTPS protocol is always supported. Other File Transfer protocols
         can be enabled on demand.";
      leaf-list enable-protocol {
        type identityref{
          base file-transfer-protocol;
        }

        description
          "Enable the file transfer protocol.";
      }
    }

    container tls-client-parameters {
      description "TLS client parameters.";
      uses tlsc:hello-params-grouping;
    }

    container client-identity {
      description
        "The credentials used by the client to authenticate to
         the SSH server.";
      leaf-list ssh-generate-auth-key {
        type ssh-auth-key-type;
        description
          "A locally-defined or referenced asymmetric key
           pair to be used for client identification.";

      }
    }

    action upload {
      nacm:default-deny-all;
      description
        "Specify the upload action. The server sends
         the file identified by the local-file-path
         to the URI identified by the remote-file-path.";

      input {
        uses upload-file-input-params;
      }

      output {
        uses file-transfer-common-output-params;
      }
    }

    action download {
      nacm:default-deny-all;
      description
        "Specify the download action. The server retrieves
        the file identified by the url remote file path
        to the local file path.";

      input {
        uses download-file-input-params;
      }

      output {
        uses file-transfer-common-output-params;
      }
    }

    action abort-file-transfer {
      nacm:default-deny-all;
      description
        "Abort the file transfer process.";
      input {
        leaf index {
          type file-transfer-request-index;
		  mandatory true;
          description
            "Abort the file transfer with index reference.";
        }
      }
    }

    action remove-files {
      nacm:default-deny-all;
      description
        "Remove downloaded files from target entity.";
      input {
        uses remove-file-category-group;
      }
    }

    notification file-transfer-status {
      description
        "Indicates that the specified file transfer status.";

      leaf index {
        type file-transfer-request-index;
        description
          "Abort the file transfer with index reference.";
      }

      leaf url {
        type inet:uri;
        mandatory true;
        description
          "URL of the remote server containing the information required to
           download or upload the specified files included
           protocol, IP address, file-path, etc..";
      }

      uses file-category-group;

      leaf status {
        type identityref{
          base file-transfer-status;
        }
   	    mandatory true;
        description
          "Status of the file transfer.";
      }

      leaf failure-reason {
        when "(derived-from-or-self (../status, 'file-transfer-failure'))" {
          description "Applicable only for trace-logs category.";
        }
        type string;
        description
          "Additional information in case of failures.";
      }
    }

    container techsupport {
      description
        "Actions authorized only to techsupport user.";
      action upload {
        nacm:default-deny-all;
        description
          "Specify the upload action. The server sends
          the file identified by the local-file-path
          to the URI identified by the remote-file-path.";

        input {
          uses upload-file-techsupport-input-params;
        }

        output {
          uses file-transfer-common-output-params;
        }
      }

      action download {
        nacm:default-deny-all;
        description
          "Specify the download action. The server retrieves
          the file identified by the url remote file path
          to the local file path.";

        input {
          uses download-file-techsupport-input-params;
        }

        output {
          uses file-transfer-common-output-params;
        }
      }

      action abort-file-transfer {
        nacm:default-deny-all;
        description
          "Abort the file transfer process.";
        input {
          leaf index {
            type file-transfer-request-index;
        mandatory true;
            description
              "Abort the file transfer with index reference.";
          }
        }
      }

      action remove-files {
        nacm:default-deny-all;
        description
          "Remove downloaded files from target entity.";
        input {
          uses remove-file-category-techsupport-group;
        }
      }
    }
  }

  container file-transfer-state {
    config false;
    description
      "Data nodes for the state of file-transfer.";
    list file-transferred {

      key index;

      leaf index {
        type file-transfer-request-index;
        mandatory true;
        description "Index.";
      }

      leaf url {
        type inet:uri;
        mandatory true;
        description
          "URL of the remote server containing the information required to
           download or upload the specified files included
           protocol, IP address, file-path, etc..";
      }

      uses file-category-group;

      leaf credential-method {
        type enumeration {
          enum password{
            description "Password credential method.";
          }
          enum certificate{
            description "Certificate credential method.";
          }
          enum ssh-key{
            description "SSH-key credential method.";
          }
        }
        description "Credential method";
      }

      container "transfer-status" {

        config false;
        description "Transfer status.";

        leaf transfer-status {
          type identityref{
            base file-transfer-status;
          }
          mandatory true;
          description "Transfer status.";
        }

        leaf failure-reason {
          when "(derived-from-or-self (../transfer-status, 'file-transfer-failure'))" {
            description "Applicable only in case of file-transfer-failure.";
          }
          type string;
          description
            "Additional information in case of failures.";
        }

        leaf progress {
          when "(derived-from-or-self (../transfer-status, 'file-transfer-inprogress')) and " +
               "not(starts-with(../../url, 'tftp'))" {
            description "Applicable only in case of file-transfer is ongoing and the protocol is not tftp";
          }
          type percent;
          mandatory true;
          description "Transfer progress.";
        }

        leaf timestamp {
          when "(derived-from-or-self (../transfer-status, 'file-transfer-success'))" {
            description "Applicable only in case of Upload file-transfer success.";
          }
          type yang:date-and-time;
          description
            "The time and date when the file was uploaded/downloaded.";
        }

        leaf compressed-file-name {
          when "(derived-from-or-self (../transfer-status, 'file-transfer-success')) and " +
               "not(derived-from-or-self (../../category/category-type, 'ztp-certificate'))" {
            description "Applicable only in case of file-transfer success.";
          }
          type string;
          description
            "By default compression is enabled during upload.  This leaf
             specifies the name of the compressed file.  If not specified
             as part of the URL, the file name shall be auto-generated by
             the system.
             This leaf is applicable only in case of upload requests.
             For Download requests, the value of this leaf shall be empty. ";
        }

        leaf md5-checksum {
          when "(derived-from-or-self (../transfer-status, 'file-transfer-success'))" {
            description "Applicable only in case of file-transfer success.";
          }
          type string;
          description
            "MD5 Checksum Value of the compressed file in case of upload or
             the downloaded file in case of download.";
        }
      }
      description "File transferred list.";
    }

    container available {
      description "Available.";

      container upload-files {

        config false;
        description "Upload files.";

        list category {
          key category-type;
          description "Category list.";

          leaf category-type {
            type upload-file-category-type;
            description "Category type.";
          }

          uses file-category-state-params ;
        }
      }

      container download-files {

        config false;
        description "Download files.";

        list category {
          key category-type;
          description "Category list.";

          leaf category-type {
            type download-file-category-type;
            description "Category type";
          }

          uses file-category-state-params;
        }
      }
    }

    container ssh-auth-publickey {
      description "SSH Authentication public keys.";
      list ssh-public-keys {
        key key-type;
        description "SSH public key list.";

        leaf key-type {
          type ssh-auth-key-type;
          description
            "A locally-defined or referenced asymmetric key
             pair to be used for client identification.";
        }
        leaf public-key {
          type binary;
          description
            "A locally generated authentication key
             pair in the system in openSSL format.";
        }
      }
    }

    container techsupport {
      config false;
      description "Techsupport.";

      list file-transferred {

        key index;
        description "File Transferred list.";

        leaf index {
          type file-transfer-request-index;
          mandatory true;
          description "Index.";
        }

        leaf url {
          type inet:uri;
          mandatory true;
          description
            "URL of the remote server containing the information required to
            download or upload the specified files included
            protocol, IP address, file-path, etc..";
        }

        uses file-category-techsupport-group;

        leaf credential-method {
          type enumeration {
            enum password{
              description "Password credential method.";
            }
            enum certificate{
              description "Certificate credential method.";
            }
            enum ssh-key{
              description "SSH-key credential method.";
            }
          }
          description "Credential method.";
        }

        container "transfer-status" {
          config false;
          description "Transfer Status.";

          leaf transfer-status {
            type identityref{
              base file-transfer-status;
            }
            mandatory true;
            description "Transfer Status.";
          }

          leaf failure-reason {
            when "(derived-from-or-self (../transfer-status, 'file-transfer-failure'))" {
              description "Applicable only in case of file-transfer-failure.";
            }
            type string;
            description
              "Additional information in case of failures.";
          }

          leaf progress {
            when "(derived-from-or-self (../transfer-status, 'file-transfer-inprogress')) and " +
                "not(starts-with(../../url, 'tftp'))" {
              description "Applicable only in case of file-transfer is ongoing and the protocol is not tftp";
            }
            type percent;
            mandatory true;
            description "Transfer progress.";
          }

          leaf timestamp {
            when "(derived-from-or-self (../transfer-status, 'file-transfer-success'))" {
              description "Applicable only in case of Upload file-transfer success.";
            }
            type yang:date-and-time;
            description
              "The time and date when the file was uploaded/downloaded.";
          }

          leaf compressed-file-name {
            when "(derived-from-or-self (../transfer-status, 'file-transfer-success'))" {
              description "Applicable only in case of file-transfer success.";
            }
            type string;
            description
              "By default compression is enabled during upload.  This leaf
              specifies the name of the compressed file.  If not specified
              as part of the URL, the file name shall be auto-generated by
              the system.
              This leaf is applicable only in case of upload requests.
              For Download requests, the value of this leaf shall be empty. ";
          }

          leaf md5-checksum {
            when "(derived-from-or-self (../transfer-status, 'file-transfer-success'))" {
              description "Applicable only in case of file-transfer success.";
            }
            type string;
            description
              "MD5 Checksum Value of the compressed file in case of upload or
              the downloaded file in case of download.";
          }
        }
      }

      container available {
        description "Available.";

        container upload-files {
          config false;
          description "Upload files.";

          list category {
            key category-type;
            description "Category list.";

            leaf category-type {
              type upload-file-category-techsupport-type;
              description "Category type.";
            }

            uses file-category-state-directories-params ;
          }
        }

        container download-files {
          config false;
          description "Download files.";

          list category {
            key category-type;
            description "Category list.";

            leaf category-type {
              type download-file-category-techsupport-type;
              description "Category type.";
            }

            uses file-category-state-params;
          }
        }
      }
    }
  }

  augment "/nokia-ft:file-transfer/nokia-ft:download/nokia-ft:input/nokia-ft:credentials/nokia-ft:certificate/nokia-ft:server-auth" {
    description "Augments CA certificate configuration with a reference to an EST CA certificate profile";
    uses estc:est-ca-certificate-profile-ref-grouping;
  }

  augment "/nokia-ft:file-transfer/nokia-ft:upload/nokia-ft:input/nokia-ft:credentials/nokia-ft:certificate/nokia-ft:server-auth" {
    description "Augments CA certificate configuration with a reference to an EST CA certificate profile";
    uses estc:est-ca-certificate-profile-ref-grouping;
  }

  augment "/nokia-ft:file-transfer/nokia-ft:techsupport/nokia-ft:download/nokia-ft:input/nokia-ft:credentials/nokia-ft:certificate/nokia-ft:server-auth" {
    description "Augments CA certificate configuration with a reference to an EST CA certificate profile";
    uses estc:est-ca-certificate-profile-ref-grouping;
  }

  augment "/nokia-ft:file-transfer/nokia-ft:techsupport/nokia-ft:upload/nokia-ft:input/nokia-ft:credentials/nokia-ft:certificate/nokia-ft:server-auth" {
    description "Augments CA certificate configuration with a reference to an EST CA certificate profile";
    uses estc:est-ca-certificate-profile-ref-grouping;
  }

}
