        ((current()/../../../../nokia-hw-prof-mounted:tca-profiles/nokia-hw-pm-threshold-prof-mounted:pm-profiles/nokia-eth-pm-tca-prof-mounted:ethernet-frame-error-profile[nokia-eth-pm-tca-prof-mounted:name = current()]/nokia-eth-pm-tca-prof-mounted:oversize-pkts-threshold < 4294967295) or (not(current()/../../../../nokia-hw-prof-mounted:tca-profiles/nokia-hw-pm-threshold-prof-mounted:pm-profiles/nokia-eth-pm-tca-prof-mounted:ethernet-frame-error-profile[nokia-eth-pm-tca-prof-mounted:name = current()]/nokia-eth-pm-tca-prof-mounted:oversize-pkts-threshold)))))
        or (current()/../pm-counter-size = '64bit-performance-monitoring'))" {
