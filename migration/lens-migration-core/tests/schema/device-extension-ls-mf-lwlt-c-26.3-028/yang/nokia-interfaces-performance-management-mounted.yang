      }

  }

  augment "/onu:onus/onu:onu/onu:root/if-mounted:interfaces-state/if-mounted:interface/bbf-if-pm-mounted:performance"
        + "/bbf-if-pm-mounted:intervals-15min/bbf-if-pm-mounted:current" {
    when
      "derived-from-or-self(../../../if-mounted:type, 'nokia-if-id-mounted:moca-uni')" {
      description
        "The interfaces applicable for Moca Uni threshold crossing alert.";
    }
    description
      "Data nodes for the Moca uni performance monitorting threshold crossing alerts";
    notification moca-threshold-crossing-alert {
      description
        "A threshold has been crossed during the current 15-min interval";
      leaf tca-identity {
        type identityref {
          base nokia-moca-pm-tca-prof-mounted:moca-pm-tca-alert;
        }
        mandatory true;
        description
          "Indicating which TCA element has reached the threshold value";
      }
      leaf notification-text {
        type string;
        description
          "The description string used to inform the operators about the notification event";
      }
    }

  }

  augment "/onu:onus/onu:onu/onu:root/if-mounted:interfaces-state/if-mounted:interface/bbf-if-pm-mounted:performance/bbf-if-pm-mounted:intervals-15min/bbf-if-pm-mounted:history/bbf-xpon-pm-mounted:xpon/bbf-xpon-pm-mounted:gemport" {
    description
      "Performance state data augmentation. Aggregate GEM frame inbound/outbound performance counters";

    uses nokia-xpongemtcont-gemport-pm-mounted:gemport-packets-pm;
  }
  augment "/onu:onus/onu:onu/onu:root/if-mounted:interfaces-state/if-mounted:interface/bbf-if-pm-mounted:performance/bbf-if-pm-mounted:intervals-15min/bbf-if-pm-mounted:current/bbf-xpon-pm-mounted:xpon/bbf-xpon-pm-mounted:gemport" {
    description
      "Performance state data augmentation. Aggregate GEM frame inbound/outbound performance counters";

    uses nokia-xpongemtcont-gemport-pm-mounted:gemport-packets-pm;
  }

  augment "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/nokia-sdan-if-mounted:all-unis/nokia-sdan-if-mounted:ethernet" {
    description "augment interface with performance parameters";
    container performance {
      
      presence "If container is not present, performance monitoring is disabled.
                If container is present performance monitoring is disabled or enabled
                depending on the value of 'enable' leaf.";
      description
        "Performance parameters.";
      leaf enable {
        type boolean;
        default "false";
        description
          "If true, enables aggrigated Ethernet performance counters.

           The performance counters will be available under
           '/onu:onus/onu:onu/onu:root/if-mounted:interfaces-state
           /nokia-sdan-if-mounted:all-unis/nokia-sdan-if-mounted:ethernet/nokia-interfaces-performance
           -management-mounted:performance/' for 15 minute and,
           if supported, 24 hour current and historic intervals.

           If false, then there are no performance counters available
           on this interface.";
      }
    }
  }

  augment "/onu:onus/onu:onu/onu:root/if-mounted:interfaces-state/nokia-sdan-if-mounted:all-unis/nokia-sdan-if-mounted:ethernet" {
    description
      "Performance state data augmentation.";
    container performance {
      description
        "Performance monitoring parameters.";
      container intervals-15min {
        description
          "15 minute interval performance history.";
        container current {
          description
            "Contains the performance data for the current interval.";
          uses all-ethernet-uni-aggregated-traffic-counters;
        }
        uses bbf-if-pm-mounted:performance-15min-history-parameters;
        list history {
          key "interval-number";
          max-elements 96;
          description
            "A history of 15 minute intervals.";
          leaf interval-number {
            type bbf-if-pm-mounted:performance-15min-history-interval;
            description
              "The number of the interval relative to the current interval.";
          }
          uses bbf-if-pm-mounted:performance-history-15min-interval-parameters;
          uses all-ethernet-uni-aggregated-traffic-counters;
        }
      }
    }
  }
  augment '/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-if-pm-mounted:performance' {
 
      when "derived-from-or-self(../if-mounted:type, 'ianaift-mounted:ethernetCsmacd') or "
           + "derived-from-or-self(../if-mounted:type, 'bbf-xponift-mounted:onu-v-vrefpoint') or "
           + "derived-from-or-self(../if-mounted:type, 'bbf-xponift-mounted:ani')"{
      }
      description "augment interface performance";
      leaf pm-counter-size {
         type enumeration {
            enum 32bit-performance-monitoring { 
              description "32bit performance monitoring";
              }
            enum 64bit-performance-monitoring {
              description "64bit performance monitoring";
              }
         }
         default "32bit-performance-monitoring";
         description
           "The size of the performance monitoring counters for the ONU interface (Supported only for the ANI and Ethernet interface).By default 32-bit performance monitoring counters will be enabled in ONU interface. If pm-counter-size is set to 64bit-performance-monitoring, 64-bit performance counters are enabled and 32-bit performance monitoring counters are disabled.";
      }        
  }
}

