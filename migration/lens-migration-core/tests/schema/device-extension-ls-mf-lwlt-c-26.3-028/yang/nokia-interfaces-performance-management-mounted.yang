  augment '/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-if-pm-mounted:performance' {
  description "pm-group";
  container ethernet {
    presence "ethernet";
    description
      "The interfaces applicable for ethernet PM group related parameters.";
    leaf-list ethernet-pm-group {
      type ethernet-interface-pm-group-type;
      must "../../../if-mounted:type = 'ianaift-mounted:ethernetCsmacd'"{
	error-message
	  "The associated PM group type is not supported on this ethernet interface";
      }
      description
	"Performance monitoring group type to enable or disable
	specific performance monitoring counters on an ethernet interface";
    }
  }
  container ani {
    presence "ani";
    description
      "The interfaces applicable for ani PM group related parameters.";
    leaf-list ani-pm-group {
      type ani-interface-pm-group-type;
      must "../../../if-mounted:type = 'bbf-xponift-mounted:ani'"{
	error-message
	  "The associated PM group type is not supported on this ani interface";
      }
      description
	"Performance monitoring group type to enable or disable
	specific performance monitoring counters on ani interface";
    }
  }
  container moca {
    presence "moca";
    description
      "The interfaces applicable for MoCA PM group related parameters.";
    leaf-list moca-pm-group {
      type moca-interface-pm-group-type;
      must "not(../../../nokia-moca-mounted:moca-home/nokia-moca-mounted:automatic-power-control)"{
        error-message
          "The associated PM group type is not supported on this MoCA service";
      }
      must "../../../if-mounted:type = 'nokia-if-id-mounted:moca-uni'"{
        error-message
          "The associated PM group type is not supported on this MoCA interface";
      }
      description
	"Performance monitoring group type to enable or disable
	specific performance monitoring counters on an MoCA access interface";
    }
  }
}
