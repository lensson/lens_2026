  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:vlan-tag-match-type/bbf-subif-tag-mounted:vlan-tagged"
           +"/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:index"{
      deviate add {
        must "current() = 0"{
               error-message "The index of the VLAN tag only support tag 0. ";
        }
     }
 }

  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:vlan-tag-match-type/bbf-subif-tag-mounted:vlan-tagged"
           +"/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:tag-type"{
      deviate add {
            must "current() = 'bbf-dot1qt:c-vlan'"{
                    error-message "The match-criteria tag type must be c-vlan.";
        }
    }
 }

  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:vlan-tag-match-type/bbf-subif-tag-mounted:vlan-tagged"
           +"/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:pbit"{
      deviate add {
            must "current() = 'any'"{
                    error-message "Match pbit of vlan-sub-interface tagged rule value other than 'any' will be rejected.";
            }
          }
 }

  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
