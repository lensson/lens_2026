module nokia-bbf-sub-interface-tagging-mounted-eonu-dev {

  namespace "http://www.nokia.com/Fixed-Networks/BBA/yang/" 
           + "nokia-bbf-sub-interface-tagging-mounted-eonu-dev";

  prefix nokia-bbf-sub-interface-tagging-mounted-eonu-dev;
  import bbf-fiber-onu-emulated-mount {
    prefix onu;
  }

  import ietf-interfaces-mounted {
    prefix if-mounted;
  }

  import bbf-sub-interface-tagging-mounted {
    prefix bbf-subif-tag-mounted;
  }

  import bbf-sub-interfaces-mounted {
    prefix bbf-subif-mounted;
  }

  import bbf-dot1q-types {
    prefix bbf-dot1qt;
  }
 
  import iana-if-type-mounted {
    prefix ianaift-mounted;
  }

  import bbf-xpon-if-type-mounted {
    prefix bbf-xponift-mounted;
  }

  organization
    "Nokia";

  contact
    "isam.yang@nokia.com";

  description
    "This module contains a collection of YANG deviations on top 
     of standard for supporting BBF/bbf-sub-interfaces-tagging YANG module.
     Copyright (C) 2017-2018, Nokia. All Rights Reserved.";

  revision 2025-11-25 {
    description
      "add match-criteria ethernet-frame-type check";
    reference
      "Nokia specific";
  }

  revision 2024-04-01 {
    description
      "add ingress-rewrite pbit/dei from-tag-index check";
    reference
      "Nokia specific";
  }

  revision 2023-11-03 {
    description
      "remove egress-rewrite check";
    reference
      "Nokia specific";
  }

  revision 2023-03-10 {
    description
      "update for egress-rewrite check.";
    reference
      "Nokia specific";
  }
 
  revision 2021-03-10 {
    description
      "Initial revision.";
    reference
      "Nokia specific"; 
  }

 
  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:frame-filter/bbf-subif-tag-mounted:destination-mac-address"{
    description
       "This deviaton assures that no inline-frame-processing can be configured for destination-mac-address.";
    deviate not-supported;
 }


  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:frame-filter/bbf-subif-tag-mounted:destination-ipv4-address"{
    description
       "This deviaton assures that no inline-frame-processing can be configured for destination-ipv4-address.";
    deviate not-supported;
 }

  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:frame-filter/bbf-subif-tag-mounted:destination-ipv6-address"{
    description
       "This deviaton assures that no inline-frame-processing can be configured for destination-ipv6-address.";
    deviate not-supported;
 }


  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:vlan-tag-match-type/bbf-subif-tag-mounted:match-all"{
    description
       "This deviaton assures that no inline-frame-processing can be configured for match-all.";
    deviate not-supported;
 }
 
 deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:ethernet-frame-type"{
     description
       "This deviaton replace type of ethernet-frame-type to only support enumeration and hex.";
     deviate replace {
          type union {
            type enumeration {
              enum any {
                description
                  "Matches any Ethertype value.";
              }
              enum ipv4 {
                description
                  "Matches the Ethertype value 0x0800 or 0x0806 or
                  0x8035.";
              }
              enum pppoe {
                description
                  "Matches the Ethertype value 0x8863 or 0x8864.";
              }
              enum ipv6 {
                description
                  "Matches the Ethertype value 0x86DD.";
              }
          }
          type bbf-dot1qt:ether-type-hex;
        }
    }
  }

 deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
            +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
            +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
            +"/bbf-subif-tag-mounted:ethernet-frame-type"{
     deviate add {
            must "(current() = 'any')"
            +"or ((boolean(current()/../bbf-subif-tag-mounted:untagged))"
            +"and ((current()/../../../../../../../if-mounted:interface[if-mounted:name = current()/../../../../../../bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface]"
            +"/if-mounted:type = 'bbf-xponift-mounted:onu-v-vrefpoint')"
            +"or  (current()/../../../../../../../if-mounted:interface[if-mounted:name = current()/../../../../../../bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface]"
            +"/if-mounted:type = 'ianaift-mounted:ethernetCsmacd')))" {
                    error-message "Filtering with ethernet frame type can only be used on untagged VSI and its lower-layer interface can only be onu-v-vrefpoint or ethernetCsmacd.";
        }
      }
 }

 deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:exclude-criteria"
           +"/bbf-subif-tag-mounted:ethernet-frame-type"{
      deviate add {
            must "(not(boolean(current()/../../bbf-subif-tag-mounted:match-criteria"
            +"/bbf-subif-tag-mounted:any-frame)))"
            +"and (current() = '0x8100')" {
                    error-message "The ethernet frame type only supports 0x8100 to identify the tag number, and can not be configured in the s-tunnel mode.";
        }
      }
 }

  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:protocols"{
     description
       "This deviaton assures that no inline-frame-processing can be configured for protocols.";
     deviate not-supported;
 }
 
  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:ingress-rewrite"
           +"/bbf-subif-tag-mounted:push-tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id-from-tag-index-or-discard"{
     description
       "This deviaton assures not support ingress-rewrite vlan-id-from-tag-index-or-discard.";
     deviate not-supported;     
 }


  deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
