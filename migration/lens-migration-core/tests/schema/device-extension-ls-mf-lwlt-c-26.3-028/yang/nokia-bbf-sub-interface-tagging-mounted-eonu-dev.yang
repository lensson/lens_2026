           +"/bbf-subif-tag-mounted:match-criteria/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'priority-tagged') and " 
           +"((current() = 0)))"{

           error-message " The match field of VLAN tags (except untag) in ingress direction NOT equal to VLAN tags pushed in egress direction  will be rejected.";

      }
   }
 }*/

 
   deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:pop-tags" {
    deviate add {
      must "(((boolean(current()/../../bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:untagged)) or (current()/../../bbf-subif-mounted:flexible-match"
           +"/bbf-subif-tag-mounted:match-criteria/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'any') or "
           +"(boolean(current()/../../bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:any-frame))) and (current() = 0)) or "
           +"((current()/../../bbf-subif-mounted:flexible-match"
           +"/bbf-subif-tag-mounted:match-criteria/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id != 'any') and (current() < 2))"{

          error-message " If match criteria is 'untag' or 'any' or 'any-frame', the ingress rewrite must pop 0 tag. If match criteria is ptag or single tag, ingress rewrite pop-tags less than 2";
      }
   }
 }
 
deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
