*/

  deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:gemports/bbf-xpongemtcont:gemport/bbf-xpongemtcont:name" {
   deviate replace {
      type nok-typ:nokia-string-ascii100;
    }
  }

  deviation "/bbf-xpongemtcont:xpongemtcont-state/bbf-xpongemtcont:gemports/bbf-xpongemtcont:gemport/bbf-xpongemtcont:name" {
   deviate replace {
      type nok-typ:nokia-string-ascii100;
    }
  }

 deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:tconts/bbf-xpongemtcont:tcont/bbf-xpongemtcont:name" {
    deviate replace {
      type nok-typ:nokia-string-ascii100;
    }
  }

 deviation "/bbf-xpongemtcont:xpongemtcont-state/bbf-xpongemtcont:tconts/bbf-xpongemtcont:tcont/bbf-xpongemtcont:name" {
   deviate replace {
      type nok-typ:nokia-string-ascii100;
    }
  }
  
 deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:traffic-descriptor-profiles/bbf-xpongemtcont:traffic-descriptor-profile/bbf-xpongemtcont:maximum-bandwidth" {
    deviate replace {
      type uint64 {
        range "0..50000000000"{
          error-message
            "Must maximum-bandwidth <= 50G.";
        }
      }
    }
  }
  
}
