module nokia-bbf-xpongemtcont-common-dev {

  namespace "http://www.nokia.com/Fixed-Networks/BBA/yang/"
    + "nokia-bbf-xpongemtcont-common-dev";

  prefix nokia-bbf-xpongemtcont-common-dev;

  import  bbf-xpongemtcont {
    prefix  bbf-xpongemtcont;
  }
  
  import nokia-yang-types {
    prefix nok-typ;
  }

  organization
    "Nokia";

  contact
    "isam.yang@nokia.com";

  description
    "The NOKIA IETF/System YANG module supporting
     deviations on top of standard.";
	 
  revision 2025-12-04 {
    description
      "Expand maximum-bandwidth range to 0..50G for all PON tech and move to common";
    reference
      "Nokia Specific.";
  }
  
  revision 2024-04-30 {
    description
      "Enlarge 64 to 100 bytes, RmtDbg gemport range change";
    reference
      "Nokia Specific.";
  }

  revision 2023-02-24 {
    description
      "bbf-xpongemtcont:tcont-ref is not supported.";
    reference
      "Nokia Specific.";
  }

  revision 2022-11-25 {
    description
      "Add not supported parameters.";
    reference
      "Nokia Specific.";
  }

  revision 2019-11-14 {
    description
      "Move upstream-aes-indicator to xpon category.";
    reference
      "Nokia Specific.";
  }

  revision 2019-07-02 {
    description
      "Initial revision.";
    reference
      "Nokia Specific.";
  }

/**********************************************/
/* definitions which should always be present */
/**********************************************/

  deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:gemports/bbf-xpongemtcont:gemport/bbf-xpongemtcont:interface" {
    deviate add {
      mandatory true;
    }
  }

  deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:gemports/bbf-xpongemtcont:gemport/bbf-xpongemtcont:traffic-class" {
    deviate add {
      mandatory true;
    }
  }

  deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:tconts/bbf-xpongemtcont:tcont/bbf-xpongemtcont:interface-reference" {
    deviate add {
      mandatory true;
    }
  }

  deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:tconts/bbf-xpongemtcont:tcont/bbf-xpongemtcont:traffic-descriptor-profile-ref" {
    deviate add {
      mandatory true;
    }
  }


  deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:traffic-descriptor-profiles/bbf-xpongemtcont:traffic-descriptor-profile/bbf-xpongemtcont:additional-bw-eligibility-indicator"{
    description "This parameter is not supported.";
    deviate not-supported;
  } 

  deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:traffic-descriptor-profiles/bbf-xpongemtcont:traffic-descriptor-profile/bbf-xpongemtcont:weight"{
    description "This parameter is not supported.";
    deviate not-supported;
  }

  deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:traffic-descriptor-profiles/bbf-xpongemtcont:traffic-descriptor-profile/bbf-xpongemtcont:priority"{
    description "This parameter is not supported.";
    deviate not-supported;
  } 

  deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:gemports/bbf-xpongemtcont:gemport/bbf-xpongemtcont:tcont-ref" {
    description "This parameter is not supported.";
    deviate not-supported;
  }


