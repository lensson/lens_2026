deviation "/bbf-xpongemtcont:xpongemtcont/bbf-xpongemtcont:tconts/bbf-xpongemtcont:tcont/bbf-xpongemtcont:alloc-id" {
  deviate add {
      must "(/if:interfaces/if:interface[if:name = 
           /if:interfaces/if:interface[if:name = current()/../bbf-xpongemtcont:interface-reference]
