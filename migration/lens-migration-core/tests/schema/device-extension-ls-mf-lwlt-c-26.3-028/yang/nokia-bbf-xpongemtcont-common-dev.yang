                  /bbf-xponvani:v-ani/bbf-xponvani:preferred-channel-pair]/bbf-xpon:channel-pair/bbf-xpon:channel-pair-type != 'bbf-xpon-types:gpon'
               and
                  current() >= 1024 and current() <= 16383)" 
      {
