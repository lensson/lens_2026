           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria" {
      deviate add {
        must "not(derived-from-or-self(../../../../../../../../onu:usage, 'template-common:node-actual-usage'))
              or
              not(boolean(current()/bbf-subif-tag-mounted:any-frame))
              or
              count(current()/../../../../../../if-mounted:interface[bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface = current()/../../../../../bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface]/
              bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria/
              bbf-subif-tag-mounted:untagged) = 0"

        {
          error-message "VSI match any-frame and VSI match untagged are not allowed under the same UNI.";
        }

      }
    }

    deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria" {
      deviate add {
        must "not(derived-from-or-self(../../../../../../../../onu:usage, 'template-common:node-actual-usage'))
              or
              count(current()/bbf-subif-tag-mounted:tag[bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'priority-tagged']) = 0
              or
              count(current()/../../../../../../if-mounted:interface[bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface = current()/../../../../../bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface]) = 1
              or
              count(current()/../../../../../../if-mounted:interface[bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface = current()/../../../../../bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface]/
              bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria/
              bbf-subif-tag-mounted:untagged) = 0"

        {
          error-message "VSI match priority-taggged and VSI match untagged are not allowed under the same UNI.";
        }

      }
    }

    deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:frame-filter/bbf-subif-tag-mounted:any-frame/bbf-subif-tag-mounted:any-frame" {
      deviate add {
        must "not(derived-from-or-self(../../../../../../../../../onu:usage, 'template-common:node-actual-usage'))
              or
              count(current()/../../../../bbf-subif-mounted:rule[bbf-subif-mounted:priority > current()/../../../bbf-subif-mounted:priority]) = 0"
        
        {
          error-message "priority of any-frame VSI should be minimum priority in all rules.";
        }
      }
    }


   deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing"
           +"/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria" {

      deviate add {

           must "((count(current()/../../../bbf-subif-mounted:rule) > 1)"
                +" or derived-from-or-self(../../../../../../../../onu:usage, 'template-common:node-actual-usage')"
                +" or ((not(boolean(current()/../../bbf-subif-mounted:ingress-rewrite/push-tag)))"
                +" and (not(boolean(current()/../../../../bbf-subif-mounted:egress-rewrite/push-tag)))"
                +" and (current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:pop-tags = 0)"
                +" and (current()/../../../../bbf-subif-mounted:egress-rewrite/pop-tags = 0))"
                +" and (not(boolean(current()/bbf-subif-tag-mounted:any-frame)))"

                +" or (boolean(current()/bbf-subif-tag-mounted:untagged))"
                +" and current()/../../../../bbf-subif-mounted:egress-rewrite/pop-tags = 1"
                +" and (boolean(current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:push-tag))"
                +" and (not(boolean(current()/../../../../bbf-subif-mounted:egress-rewrite/push-tag)))"
                +" or (current()/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'priority-tagged')"
                +" and (current()/../../../../bbf-subif-mounted:egress-rewrite/pop-tags = 1)"
                +" and (current()/../../../../bbf-subif-mounted:egress-rewrite/push-tag/bbf-subif-tag-mounted:dot1q-tag"
                +" /bbf-subif-tag-mounted:vlan-id = 0)"

                +" or (current()/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id > 0)"
                +" and (current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:pop-tags = 1)"
                +" and (current()/../../../../bbf-subif-mounted:egress-rewrite/pop-tags = 1)"
                +" and (current()/../../../../bbf-subif-mounted:egress-rewrite/bbf-subif-tag-mounted:push-tag"
                +" /bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id"
                +" = current()/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id)"

                +" or (current()/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id > 0)"
                +" and (current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:pop-tags = 1)"
                +" and (current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:push-tag"
                +" /bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = "
                +" current()/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id)"
                +" and (current()/../../../../bbf-subif-mounted:egress-rewrite/pop-tags = 0)"
                +" and (not(boolean(current()/../../../../bbf-subif-mounted:egress-rewrite/push-tag)))"

                +" or (current()/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id > 0)"
                +" and (current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:pop-tags = 0)"
                +" and (boolean(current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:push-tag))"
                +" and (current()/../../../../bbf-subif-mounted:egress-rewrite/pop-tags = 1)"

                +" or (boolean(current()/bbf-subif-tag-mounted:any-frame))"
                +" and current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:pop-tags = 0"
                +" and boolean(current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:push-tag)"
                +" and current()/../../../../bbf-subif-mounted:egress-rewrite/pop-tags = 1"
                +" and not(boolean(current()/../../../../bbf-subif-mounted:egress-rewrite/push-tag))"

                +" or ((current()/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'any')"
                +" and (not(boolean(current()/../../bbf-subif-mounted:ingress-rewrite/push-tag)))"
                +" and (not(boolean(current()/../../../../bbf-subif-mounted:egress-rewrite/push-tag)))"
                +" and (current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:pop-tags = 0)"
                +" and (current()/../../../../bbf-subif-mounted:egress-rewrite/pop-tags = 0))"

                +")"

          {
             error-message "VSI has only one match rule: If match criteria is untagged, the egress rewrite must pop 1 tag and no push; If match criteria is priority-tagged , the egress rewrite must pop 1 tag and push priority tag; If match criteria is vlan x, the egress rewrite must pop 1 and push a vlan equals to the vlan x; If match any-frame, ingress-rewrite no pop tag and push 1 tag, the egress rewrite must pop 1 tag and no push; If match vlan-id any only support transparent, no ingress-rewrite and no egress-rewrite.";

         }
    }

 }

