module nokia-bbf-sub-interface-tagging-mounted-eonu-only-dev {
  yang-version 1.1;
  namespace "http://www.nokia.com/Fixed-Networks/BBA/yang/"
           + "nokia-bbf-sub-interface-tagging-mounted-eonu-only-dev";

  prefix nokia-bbf-sub-interface-tagging-mounted-eonu-only-dev;
  import bbf-fiber-onu-emulated-mount {
    prefix onu;
  }

  import ietf-interfaces-mounted {
    prefix if-mounted;
  }

  import bbf-sub-interface-tagging-mounted {
    prefix bbf-subif-tag-mounted;
  }

  import bbf-sub-interfaces-mounted {
    prefix bbf-subif-mounted;
  }

  import nokia-template-common {
    prefix template-common;
  }

  import bbf-if-type-mounted {
    prefix bbfift-mounted;
  }

/*
  import bbf-qos-policies-mounted{
    prefix bbf-qos-pol-mounted;
  }

  import bbf-qos-classifiers-mounted{
    prefix bbf-qos-cls-mounted;
  }
*/
  organization
    "Nokia";

  contact
    "isam.yang@nokia.com";

  description
    "This module contains a collection of YANG deviations on top-
     of standard for supporting BBF/bbf-sub-interfaces-tagging YANG module.
     Copyright (C) 2017-2018, Nokia. All Rights Reserved.";

  revision 2025-11-25 {
    description
      "remove deviation to support more match untagged VSIs under the same UNI.";
    reference
      "Nokia specific";
  }

  revision 2024-01-04 {
    description
      "loosen any-frame rule validation.";
    reference
      "Nokia specific";
  }

  revision 2023-06-13 {
    description
      "Initial revision.";
    reference
      "Nokia specific";
  }


    deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:frame-filter/bbf-subif-tag-mounted:any-frame/bbf-subif-tag-mounted:any-frame" {
    deviate add {
      must "not(derived-from-or-self(../../../../../../../../../onu:usage, 'template-common:node-actual-usage'))"
          + "or not(boolean((current()/../../../../bbf-subif-mounted:rule/bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:push-tag"
          + "/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:pbit-from-tag-index)))" 
          {
            error-message "If one VSI has rule match 'any-frame', all rules' ingress-rewrite should use pbit-marking-index.";
          }
        }
    }


    deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:frame-filter/bbf-subif-tag-mounted:any-frame/bbf-subif-tag-mounted:any-frame" {
    deviate add {
      must "not(derived-from-or-self(../../../../../../../../../onu:usage, 'template-common:node-actual-usage'))
            or
            count(current()/../../../../bbf-subif-mounted:rule) < 2
            or
            (current()/../../../../../bbf-subif-mounted:egress-rewrite/pop-tags = 1
            and not(boolean(current()/../../../../../bbf-subif-mounted:egress-rewrite/push-tag)))" 
          {
            error-message "If match any-frame is in the rule, the egress-rewrite of match any-frame rule must pop 1 tag and no push.";
          }
        }
    }

    deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria"
           +"/bbf-subif-tag-mounted:frame-filter/bbf-subif-tag-mounted:any-frame/bbf-subif-tag-mounted:any-frame" {
    deviate add {
      must "not(derived-from-or-self(../../../../../../../../../onu:usage, 'template-common:node-actual-usage'))
            or 
            count(current()/../../../../bbf-subif-mounted:rule)<2
            or
            (count(current()/../../../../bbf-subif-mounted:rule)=2
             and count(current()/../../../../bbf-subif-mounted:rule[bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'priority-tagged']) = 1)"

          {
            error-message "If match any-frame is in the rule, and another rule exists in the same VSI: the another rule should only match priority-tag.";
          }
        }
    }

/*    
    deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria" {
    deviate add {
      must "not(derived-from-or-self(../../../../../../../../onu:usage, 'template-common:node-actual-usage'))
            or
            count(current()/bbf-subif-tag-mounted:tag[bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'any'])= 0
            or 
            (count(current()/../../../bbf-subif-mounted:rule) = 1
            and not(boolean(current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:push-tag))
            and current()/../../bbf-subif-mounted:ingress-rewrite/bbf-subif-tag-mounted:pop-tags = 0
            and not(boolean(current()/../../../../bbf-subif-mounted:egress-rewrite/bbf-subif-tag-mounted:push-tag))
            and current()/../../../../bbf-subif-mounted:egress-rewrite/bbf-subif-tag-mounted:pop-tags = 0
            and count(current()/../../../../../../if-mounted:interface[if-mounted:type = 'bbfift-mounted:vlan-sub-interface'][bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface = current()/../../../../../bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface]) = 1)"
          {
            error-message "If a VLAN any transparent VSI is configured under a uni port, other VSI cannot be configured in the same uni port.";
          }
        }
    }
*/

    deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria" {
    deviate add {
      must "not(derived-from-or-self(../../../../../../../../onu:usage, 'template-common:node-actual-usage'))
            or
            count(current()/bbf-subif-tag-mounted:tag[bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'any'])= 0
            or 
            (count(current()/../../../../../../if-mounted:interface[if-mounted:type = 'bbfift-mounted:vlan-sub-interface'][bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface = current()/../../../../../bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface]) = 1)"
          {
            error-message "If a VLAN any transparent VSI is configured under a uni port, other VSI cannot be configured in the same uni port.";
          }
        }
    }
	
	deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria" {
    deviate add {
      must "not(derived-from-or-self(../../../../../../../../onu:usage, 'template-common:node-actual-usage'))
            or 
            count(current()/../../../bbf-subif-mounted:rule) = 1
            or 	
            count(current()/../../../bbf-subif-mounted:rule[bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria/bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'any'])= 0"
          {
            error-message "tag any transparent rule could not co-exist with other rules under same VSI.";
          }
        }
    }

    deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria" {
      deviate add {
        must "not(derived-from-or-self(../../../../../../../../onu:usage, 'template-common:node-actual-usage'))
              or
              count(current()/bbf-subif-tag-mounted:tag[bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'priority-tagged']) = 0
              or 
              count(current()/../../../../../../if-mounted:interface[bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria/
                      bbf-subif-tag-mounted:tag/bbf-subif-tag-mounted:dot1q-tag/bbf-subif-tag-mounted:vlan-id = 'priority-tagged'][bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface =
                      current()/../../../../../bbf-subif-mounted:subif-lower-layer/bbf-subif-mounted:interface]) = 1"
        {
          error-message "More than one VSIs that match priority-taggged are not allowed under the same UNI.";
        }
      }
    }


    deviation "/onu:onus/onu:onu/onu:root/if-mounted:interfaces/if-mounted:interface/bbf-subif-mounted:frame-processing"
           +"/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:inline-frame-processing/bbf-subif-mounted:ingress-rule"
           +"/bbf-subif-mounted:rule/bbf-subif-mounted:flexible-match/bbf-subif-tag-mounted:match-criteria" {
      deviate add {
