revision 2024-05-09 {
  description
    "add flex FEC for 50G pon only.";
  reference
    "TBD";
}

revision 2022-04-19 {
  description
    "Initial revision.";
  reference
    "TBD";
}

identity hs-pon {
    base bbf-xpon-types:channel-pair-type-base;
    description
      "This identity is used to denote a HS-PON channel-pair,
       per ITU-T <TBD>.";
  }

identity fec-type-base {
    description
      "This identity is used to define different types of FEC.";
  }

identity fec-type-system-selected {
    base nokia-sdan-hspon-types:fec-type-base;
    description
      "This identity is used to specify that the system can select the FEC type
       that by default fits with the technology.";
  }

identity fec-type-ldpc {
    base nokia-sdan-hspon-types:fec-type-base;
    description
      "This identity is used to specify Low Density Parity Check FEC to be used.";
  }

identity fec-type-rs {
    base nokia-sdan-hspon-types:fec-type-base;
    description
      "This identity is used to specify Reed Solomon FEC to be used.";
  }


identity hs-pon-channel-pair-line-rate-profile-base {
  description
    "This identity is used to define the possible combinations
     of downstream and upstream line-rates for a HS-PON
     channel-pair.";
  }

identity unplanned-hs-pon-cp-line-rate {
  base nokia-sdan-hspon-types:hs-pon-channel-pair-line-rate-profile-base;
  description
    "This identity is used to denote a HS-PON channel pair with
     yet undefined downstream and upstream line rates.";
  }

identity down-50-up-25 {
  base nokia-sdan-hspon-types:hs-pon-channel-pair-line-rate-profile-base;
  description
    "This identity is used to denote a HS-PON channel pair with
     downstream 50Gbps and upstream 25Gbps|12,5Gbps dual-rate line rates.";
  }

identity down-25-up-25 {
  base nokia-sdan-hspon-types:hs-pon-channel-pair-line-rate-profile-base;
  description
    "This identity is used to denote a HS-PON channel pair with
     downstream 25Gbps and upstream 25Gbps|12,5Gbps dual-rate line rates.";
  }

  identity fec-type-ldpc-high-margin {
    base nokia-sdan-hspon-types:fec-type-base;
    description
      "This identity is used to specify High Margin LDPC FEC to be used.";
  }
}
