module nokia-sdan-hspon-types{

yang-version 1.1;

namespace "urn:broadband-forum-org:yang:nokia-sdan-hspon-types";
 
prefix nokia-sdan-hspon-types;

import bbf-xpon-types {
    prefix bbf-xpon-types;
}

