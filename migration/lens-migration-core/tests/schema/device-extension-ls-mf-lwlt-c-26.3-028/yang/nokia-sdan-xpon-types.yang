module nokia-sdan-xpon-types{
 yang-version 1.1;
 namespace "urn:broadband-forum-org:yang:nokia-sdan-xpon-types";

prefix nokia-sdan-xpon-types;

import bbf-xpon-types {
    prefix bbf-xpon-types;
}

