revision 2022-03-09 {
  description
    "add Nokia under Non-Disclosure Agreement(s)";
  reference
    "TBD";
}

revision 2021-12-09 {
  description
    "Initial revision.";
  reference
    "TBD";
}

identity twentyfivegs {
    base bbf-xpon-types:channel-pair-type-base;
    description
      "This identity is used to denote a 25GS-PON channel-pair,
       per 25GS-PON MSA";
  }


identity twentyfivegs-channel-pair-line-rate-profile-base {
    description
      "This identity is used to define the possible combinations of
       downstream and upstream line-rates for a
       25GS-PON channel-pair.";
}

identity unplanned-25gs-cp-line-rate {
    base
      nokia-sdan-xpon-types:twentyfivegs-channel-pair-line-rate-profile-base;
    description
      "This identity is used to denote a 25GS-PON channel pair
       with yet undefined downstream and upstream line rates.";
}

identity down-25-up-10 {
    base
      nokia-sdan-xpon-types:twentyfivegs-channel-pair-line-rate-profile-base;
    description
      "This identity is used to denote an 25GS-PON channel-pair
       with DS:25Gbps and US:10Gbps line-rates.";
}

identity down-25-up-25 {
    base
      nokia-sdan-xpon-types:twentyfivegs-channel-pair-line-rate-profile-base;
    description
      "This identity is used to denote an 25GS-PON channel-pair
       with DS:25Gbps and US:25Gbps line-rates.";
}

typedef nokia-composite-downstream-wavelength-type {
    type union {
      type uint32 {
        range "0 | 156000..161000";
      }
      type enumeration {
        enum "25gs-pon" {
          description
            "To be used in case of 25GS-PON.";
        }
      }
    }
    description "type nokia-composite-downstream-wavelength-type";
  }
}
