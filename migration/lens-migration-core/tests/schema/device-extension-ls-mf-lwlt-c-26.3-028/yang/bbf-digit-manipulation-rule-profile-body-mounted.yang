  grouping dm-rule-parameters {
    description
      "Digit manipulation rule parameters.";
    leaf dm-rule {
	  type bbf-yang:name-string;	
	  description
		"A rule is built up of key words and configurable
		 values which must be configured according to a
		 predetermined order. The position of the key words
		 and configurable values may be different
 		 depending on the manipulation rule type.
 		 The following rule types are supported whereby only
		 1 rule type can be configured for a rule :		
                  	1) [outg-use-default-pbx-number:numericvalue]
		 The manipulation rule consists of a fixed character
		 string 'outg-use-default-pbx-number:'
		 It is immediately followed by a numeric value with
		 a  range [0,1].
		 It is not allowed to insert a space between the
		 fixed character string and the numeric value.                    	
                  	2)  [inc-add-phone-context-to-number]
		 The manipulation rule consists of a fixed character
		 string 'inc-add-phone-context-to-number'.
					3)  [outg-add-country-area-code-in-phone-context:
		 countrycode-areacode]
		 The manipulation rule consists of a fixed character
		 string 
		 'outg-add-country-area-code-in-phone-context:'.
		 It is immediately followed by 2 numeric values 
		 combined with a hyphen. 
		 It is not allowed to insert a space between the fixed
		 character string and the numeric value nor between
		 the numeric value and the combining hyphen.
		 The country code can be 1..3 digits long while the area
		 code can be 1..5 digits long.
                  	4)  [inc-short-number-len:shortnumberlength] 
		 The manipulation rule consists of a fixed character
		 string 'inc-short-number-len:'. It is immediately
		 followed by a numeric value with a  range [1,9].
		 It is not allowed to insert a space between the fixed 
		 character string and the numeric value.                     	
                  	5)[outg-add-domain-name-in-phone-context]
		 The manipulation rule consists of a fixed character 
		 string 'outg-add-domain-name-in-phone-context'
		 This rule type does not require the domain name to be
		 configured as part of the manipulation rule.
					6)[out-dialedprefix-outprefix]
		 The manipulation rule consists of a fixed character
		 string 'out-dialedprefix-outprefix'
		 It is immediately followed by the dialing number rule map. 
		 It is not allowed to insert a space between
		 the fixed character string and rule map nor between the 
		 rule map and the combining hyphen.
                     	
					7)[outg-add-country-area-code-in-cpn:
		 countrycode-areacode]
		 The manipulation rule consists of a fixed character 
		 string 'outg-add-country-area-code-in-cpn:'.
		 It is immediately followed by 2 numeric values combined 
		 with a hyphen. It is not allowed to insert a 
		 space between the fixed character string and the numeric 
		 value nor between the numeric value and the
		 combining hyphen. The country code can be 1..3 digits
		 long while the area code can be 1..5 digits long

					8)[inc-del-local-country-code-in-cpn:countrycode] 
		 The manipulation rule consists of a fixed character
		 string 'inc-del-local-country-code-in-cpn:'. 
		 It is immediately followed by a numeric value. It is not 
		 allowed to insert a space between the fixed
		 character string and the numeric value. The country code 
		 can be 1..3 digits long.";
    }
	leaf dm-rule-type {
	  type enumeration {
		enum individual-pots-user-interface {
		  value 1;
		  description
			"The rule is a POTS rule that applies to
			 a single POTS user interface or a POTS 
			 rule that applies to a subset of the POTS 
			 user interfaces present in the NE.";
		}
		enum all-pots-user-interfaces {
		  value 2;
		  description
			"The rule is a POTS rule that applies to
			 all POTS user interfaces present in the NE.";
		}
	  }		
	  description
		"The digit manipulation rule type.";
	}
	leaf dm-rule-state {
	  type enumeration {
		enum activated {
		  value 1;
		  description
			"The rule is activated.";
		}
		enum de-activated {
		  value 2;
		  description
			"The rule is de-activated.";
		}
	  }
	  default de-activated;		
	  description
		"The state of the digit manipulation rule i.e. whether 
		 it is actually activated or de-activated by the operator.";
	} 
  }
  
  grouping digit-manipulation-rule-profile-body {
    description
      "Defines the parameters included in the 
	   digit-manipulation-rule profile.";
	list digit-manipulation-rules { 
	  key "index";
	  leaf index {
	    type uint16;
		description
		  "Index.";
	  }
      uses dm-rule-parameters;
	}
  }
}