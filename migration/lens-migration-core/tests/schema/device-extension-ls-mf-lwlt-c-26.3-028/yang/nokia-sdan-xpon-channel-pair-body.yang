module nokia-sdan-xpon-channel-pair-body{
 yang-version 1.1;
 namespace "urn:broadband-forum-org:yang:nokia-sdan-xpon-channel-pair-body";

prefix nokia-sdan-xpon-channel-pair-body;

import bbf-xpon{
    prefix bbf-xpon;
}

import ietf-interfaces {
    prefix if;
  }

import nokia-sdan-xpon-types {
    prefix nokia-sdan-xpon-types;
}

import nokia-sdan-hspon-types {
    prefix nokia-sdan-hspon-types;
}

import bbf-xpon-types {
    prefix bbf-xpon-types;
}

