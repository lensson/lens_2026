revision 2025-11-24 {
  description
    "add us-omci-granting.";
  reference
    "TBD";
}

revision 2024-04-15 {
  description
    "add Green DBA.";
  reference
    "TBD";
}

revision 2023-04-18 {
  description
    "update description of burst-overhead.";
  reference
    "TBD";
}

revision 2023-02-17 {
  description
    "add burst-overhead.";
  reference
    "TBD";
}

revision 2022-06-07 {
  description
    "add HSPON channel pair line rate.";
  reference
    "TBD";
}

revision 2022-03-09 {
  description
    "add Nokia under Non-Disclosure Agreement(s)";
  reference
    "TBD";
}

revision 2021-01-05 {
  description
    "Initial revision.";
  reference
    "TBD";
}

  augment '/if:interfaces/if:interface/bbf-xpon:channel-pair' {
   description "augmnet channel pair with ultra low latency mode";
   leaf ultra-low-latency-mode {
      when 
      "current()/../bbf-xpon:channel-pair-type = 
         'nokia-sdan-xpon-types:twentyfivegs'";
      type boolean;
      default "false";
      description
        "Used to Enable/Disable ultra-low latency mode.";
    }

   leaf twentyfivegs-channel-pair-line-rate {
      when "derived-from-or-self" +
           "(../bbf-xpon:channel-pair-type," +
           "'nokia-sdan-xpon-types:twentyfivegs')";

      type identityref {
      base "nokia-sdan-xpon-types:"+
           "twentyfivegs-channel-pair-line-rate-profile-base";
   }
      default
           "nokia-sdan-xpon-types:unplanned-25gs-cp-line-rate";
      description
           "Represents the planned downstream/upstream channel-pair
           speed for 25GS-PON.";
    }
    
    leaf hs-pon-channel-pair-line-rate {
      when "derived-from-or-self" +
           "(../bbf-xpon:channel-pair-type," +
           "'nokia-sdan-hspon-types:hs-pon')";
      type identityref {
        base "nokia-sdan-hspon-types:"+
             "hs-pon-channel-pair-line-rate-profile-base";
      }
      default
        "nokia-sdan-hspon-types:unplanned-hs-pon-cp-line-rate";
      description
        "Represents the planned downstream/upstream channel-pair
         speed for HS-PON.";
    }

    leaf burst-overhead {
      when
        "current()/../bbf-xpon:channel-pair-type = 'bbf-xpon-types:xgs'";
      type enumeration {
        enum "auto" {
          description
            "If burst overhead is configured to 'auto', the CAC will
             assume the worst-case and limit the configurable committed
             and assured services as such.
             Note that the inserted optical module might be capable of
             a lower PLOu, which DBA will use, but only best-effort
             services will be able to benefit from that in that case.";
        }
        enum "robust" {
          description
            "Robust PLOu size.";
        }
        enum "reduced" {
          description
            "Reduced PLOu size.
             Note that when 'reduced' is configured but the inserted
             optical module does not support it, an SFP mismatch alarm
             must be raised and the PON must stay down.
             If this is the case for one of the type-B channel-terminations,
             it will stay down and SWO is not possible.";
        }
      }
      default "auto";
      description
        "Represents the physical layer overhead (PLOu).
         The provisioned burst overhead is taken into account for service validation
         and remaining bandwidth calculation.";
    }

    leaf green-dba {
      type enumeration {
        enum "auto" {
          description
            "If Green DBA is configured to 'auto', the internal default
             in DBA will apply.";
        }
        enum "disabled" {
          description
            "Green DBA is disabled.";
        }
        enum "enabled" {
          description
             "Green DBA is enabled.";
         }
      }
      default "auto";
      description
        "Determines whether or not the Green DBA algorithm is used as DBA BW
         assignment algorithm in the uncongested case (the case in which the
         total upstream BW demand is smaller than the available upstream BW
         for the PON).";
    }

    leaf us-omci-granting {
      type enumeration {
        enum "conservative" {
          description
            "Higher OMCI overhead on PON interface.";
        }
        enum "relaxed" {
          description
            "Eligible PON interfaces will apply a lower OMCI overhead
             by relaxing the frequency of the OMCI upstream allocations
             towards the ONUs. 'relaxed' value though accepted by the system,
             it will be ignored on GPON channel-pairs and on non-Quillion boards.";
        }
      }
      default "conservative";
      description
        "This channel-pair level attribute modifies the frequency at which
         the OLT channel-pair port will allocate grants to the ONUs for
         their OMCI communication. It therefore influences the amount of
         management overhead on the channel-pair (less bandwidth reserved
         for OMCI means more useful bandwidth for user traffic).
         channel-pair interfaces supporting the relaxed behavior are
         XGS-PON, 25GS-PON and 50G-PON interfaces on Quillion-based line-cards.";
    }

  }
}
