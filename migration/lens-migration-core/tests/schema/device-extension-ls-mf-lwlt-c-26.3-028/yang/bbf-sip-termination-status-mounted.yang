     the TR itself for full legal notices.";

  revision 2020-03-06 {
    description
      "Initial revision.
       * Approval Date:    see revision date above.
       * Publication Date: 2020-03-06.";
    reference
      " ";
  }
	
  grouping sip-termination-status {  
    leaf sip-pots-uni-contact-user-info {
	  type string {length "1..128";}
	  config false;
	  description
	    "The user-part of the contact header in the SIP messages 
	     associated with the sip POTS user itf.";
    }
	leaf sip-termination-call-state {
	  type enumeration {
	    enum onhook {
		  value 0;
		  description
		    "Idle, on hook.";
        }
		enum offhook-dialtone {
		  value 1;
		  description
		    "The subscriber goes off hook and dial tone is played.";
        }
		enum dialing {
		  value 2;
		  description
		    "The subscriber is dialing.";
        }
		enum play-ring-tone {
		  value 3;
		  description
		    "The ringing tone is being played at the subscriber 
			 line.";
	    }
		enum play-ringback-tone {
		  value 4;
		  description
		    "The ringback tone is being played at the calling 
			 subscriber line.";
	    }
	    enum connecting {
		  value 5;
		  description 
		    "The call is in a connecting phase.The NE has sent a SIP 
			 INVITE request and is awaiting the response.";
	    }
	    enum connected {
		  value 6;
		  description
		    "The call has been established and is stable call 
			 phase.";
	    }
		enum releasing {
		  value 7;
		  description
		    "The call has terminated. However the subscriber did not
		     go on-hook yet. The subscriber line is in releasing 
			 state. A particular tone may be put at the subscriber 
			 line in this state.";
	    }
	    enum parking {
		  value 8;
		  description
		    "The subscriber line is in idle off-hook state, no tone
			 is generated.";
	    }
		enum roh-tone {
          value 9;
          description 
            "Warning the subscriber of an off-hook state by 
			 generating a receiver off hook (ROH) tone.";
        }	
		enum unknown-state {
		  value 10;
          description 
            "Indicates an unknown state.";
        }		
	    enum shared-cut-off {
		  value 11;
		  description
		    "This call state applies to the shared line only. When a 
		     SIP user of the shared subscriber line is involved in 
			 a call, the other SIP user, sharing the same subscriber
		     line, goes to shared-cut-off state. The SIP user in 
		     shared-cut-off state hears silence if it would go to 
		     off-hook state. An incoming call request for this SIP 
		     user will be rejected.";
	    }        		
	  }
	  config false;	
	  description
	    "The call state of the sip POTS termination.";
    }
    leaf sip-termination-registration-state {
	  type enumeration {
	    enum initial {
		  value 0;
		  description  
		    "Initial state, no registration is sent yet.";
		}
		enum registered {
		  value 1;
		  description  
		    "The termination is successfully registered.";
		}
		enum reg-fail-auth {
		  value 2;
		  description  
		    "Registration failed due to an authentication failure.";
		}
		enum reg-fail-timeout {
		  value 3;
		  description  
		    "Registration failed due to an message timeput.";
		}
		enum reg-fail-server {
		  value 4;
		  description  
		    "Registration failed due to a server failure.";
		}
	  }		
	  config false;
	  default initial;
	  description
		"Indicates the SIP termination registration status."; 
	}
	leaf emergency-call-status {
	  type enumeration {
	    enum no-emergency {
		  value 0;
		  description  
		    "No emergency call in progress.";
		}
		enum emergency-in-progress {
		  value 1;
		  description  
		    "Emergency call in progress.";
		}
	  }		
	  config false;
	  default no-emergency;
	  description
		"Indicating if an emergency call is ongoing or not.";
    }   
  }  
}

