  deviation "/onu:onus/onu:onu/onu:root/nokia-hw-prof-mounted:tca-profiles/nokia-hw-pm-threshold-prof-mounted:pm-profiles/nokia-eth-pm-tca-prof-mounted:ethernet-physical-layer-error-profile/nokia-eth-pm-tca-prof-mounted:carrier-sense-error-threshold" {
    description
      "This deviation limits the values of the threshold between 1 and (2^32)-2.";
    deviate replace {
