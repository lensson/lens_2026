      "This deviation limits the values of the threshold between 1 and (2^32)-2.";
    deviate replace {
      type uint32 {
        range "1..4294967294";
      }
    }
  }
  
  deviation "/onu:onus/onu:onu/onu:root/nokia-hw-prof-mounted:tca-profiles/nokia-hw-pm-threshold-prof-mounted:pm-profiles/nokia-eth-pm-tca-prof-mounted:ethernet-frame-error-extended-profile" {
    deviate add {
      must "count(current()/../nokia-eth-pm-tca-prof-mounted:ethernet-frame-error-extended-profile) <= 10" {
      error-message "Exceeds maximum number of ethernet-frame-error-extended-profile supported in the system.";
