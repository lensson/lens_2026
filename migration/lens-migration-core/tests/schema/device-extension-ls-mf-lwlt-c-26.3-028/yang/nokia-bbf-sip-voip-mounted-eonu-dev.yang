          + "/bbf-sip-voip-mounted:control" {
        description
          "This deviation assures that control leaf is restriced to 'operator'.";
        deviate add
        {
          must "(current() = 'operator')" {
            error-message "control must be 'operator'.";
          }
        }
    }
