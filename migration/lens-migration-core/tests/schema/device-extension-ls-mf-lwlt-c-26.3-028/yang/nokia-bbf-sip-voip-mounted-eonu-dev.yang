          + "/bbf-sip-voip-mounted:digit-map-pattern" {
        description
            "Specifies the actual digit map ascii symbols and assures that only one digit-map-pattern can be configured.";
        deviate replace {
            type string {
                length "0..1024";
                pattern '[ -~]*';
            }
        }
        deviate add {
            max-elements 1;
        }
    }

