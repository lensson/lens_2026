module nokia-sdan-moca-pm-threshold-profiles-mounted-eonu-dev {

  namespace "http://www.nokia.com/Fixed-Networks/BBA/yang/"
  + "nokia-sdan-moca-pm-threshold-profiles-mounted-eonu-dev";
  prefix nokia-moca-pm-tca-prof-mounted-eonu-dev;

  import bbf-fiber-onu-emulated-mount {
    prefix onu;
